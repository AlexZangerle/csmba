import "https://raw.githubusercontent.com/CollaborativeStateMachines/Cirrina/refs/heads/develop/src/main/resources/pkl/csm/csml.pkl"
import "../events.pkl" as Events
import "../variables.pkl" as Vars
// This module contains actions for the fireDetection SM


// Raise to start detecting fire
aRaiseStartDetectingFire = new csml.Emit {
  event = new csml.Internal {
    topic = Events.eStartDetectingFire
  }
}

// Raised to trigger fire alarm or smoke alert
aRaiseFireAlarm = new csml.Emit {
  event {
    topic = Events.eFireAlarm
    data {
      [Vars.vEmergencyInRoom] = Vars.vEmergencyInRoom
    }
  }
}

aRaiseSmokeAlert = new csml.Emit {
  event {
    topic = Events.eSmokeAlert
  }
}
