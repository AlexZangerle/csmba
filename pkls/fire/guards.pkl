// This module contains all guards for fireDetection SM

// Guard to check if fire or smoke has been detected
fireDetectedGuard = "\(Vars.vFireDetectionResult) == 'fire'"

smokeDetectedGuard = "\(Vars.vFireDetectionResult) == 'smoke'"

roomInEmergencyGuard = "\(Vars.vEmergencyInRoom) != 'none'"
