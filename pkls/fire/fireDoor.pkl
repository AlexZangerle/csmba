import "https://raw.githubusercontent.com/CollaborativeStateMachines/Cirrina/refs/heads/develop/src/main/resources/pkl/csm/csml.pkl"
import "../events.pkl" as Events
import "../serviceTypes.pkl" as ServiceTypes
import "../variables.pkl" as Vars

// Fire door state machine definition.
//
// Closes on fire alarm, reopens when disarmed. Nested inside fireDetection.
sm = new csml.StateMachine {
  states {
    ["open"] = openDoor
    ["close"] = closeDoor
  }
}

local openDoor: csml.Initial = new {
  entry {
    new csml.Invoke { type = ServiceTypes.stOpenFireDoor input { ["roomId"] = Vars.vDoorId } }
  }
  on {
    [Events.eFireAlarm] { to = "close" }
  }
}

local closeDoor: csml.State = new {
  entry {
    new csml.Invoke { type = ServiceTypes.stCloseFireDoor input { ["roomId"] = Vars.vDoorId } }
  }
  on {
    [Events.eDisarmFireAlarm] { to = "open" }
  }
}
