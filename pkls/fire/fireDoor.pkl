import
  "https://raw.githubusercontent.com/CollaborativeStateMachines/Cirrina/refs/heads/develop/src/main/resources/pkl/csm/csml.pkl"

import "../variables.pkl" as Vars

// Fire door state machine definition.
//
// Closes on fire alarm, reopens when disarmed
sm = new csml.StateMachine {
  states {
    ["open"] = openDoor
    ["close"] = closeDoor
  }
}

local openDoor: csml.Initial = new {
  entry {
    new csml.Invoke { type = "openFireDoorService"; input { ["doorId"] = Vars.vDoorId } }
  }
  on {
    ["fireAlarm"] { to = "close" }
  }
}

local closeDoor: csml.State = new {
  entry {
    new csml.Invoke { type = "closeFireDoorService"; input { ["doorId"] = Vars.vDoorId } }
  }
  on {
    ["disarmFireAlarm"] { to = "open" }
  }
}
