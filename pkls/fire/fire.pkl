import "https://raw.githubusercontent.com/CollaborativeStateMachines/Cirrina/refs/heads/develop/src/main/resources/pkl/csm/csml.pkl"
import "../events.pkl" as Events
import "actions.pkl" as Actions
import "context.pkl" as Context
import "guards.pkl" as Guards
import "../serviceTypes.pkl" as ServiceTypes
import "../variables.pkl" as Vars
import "fireDoor.pkl"

// This module contains the definition for the fireDetection SM
sm = new csml.StateMachine {
  stateMachines {
    ["fireDoor"] = fireDoor.sm
  }
  transient = Context.fireDetectionContext
  states {
    ["init"] = init
    ["detecting"] = detecting
    ["checkSmoke"] = checkSmoke
    ["fireAlarm"] = fireAlarm
    ["smokeAlert"] = smokeAlert
  }
}

// Always transitions to detecting state
local const init: csml.Initial = new {
  always {
    new csml.Transition { to = "detecting" }
  }
}

// This state waits for sensor data and invokes detection logic
local const detecting: csml.State = new {
  on {
    [Events.eSensorFireDataReceived] = new csml.Transition {
      do {
        new csml.Invoke {
          type = ServiceTypes.stDetectFire
          input {
            ["imageData"] = "$imageData"
            ["zoneId"] = "$zoneId"
          }
          raises { new csml.Internal { topic = Events.eFireDetectionComplete } }
        }
      }
    }

    [Events.eFireDetectionComplete] = new csml.Transition {
      do {
        new csml.Eval { expression = "\(Vars.vFireDetectionResult) = $fireDetectionResult" }
        new csml.Eval { expression = "\(Vars.vEmergencyInRoom) = $emergencyInRoom" }
        new csml.Raise { event = new csml.Internal { topic = "processDetectionResult" } }
      }
    }
    ["processDetectionResult"] = new csml.Transition {
      to = "fireAlarm"
      iif = Guards.fireDetectedGuard
      or = "checkSmoke"
    }
  }
}

// Helper state/logic for checking smoke if fire wasn't found
local const checkSmoke: csml.State = new {
  always {
    new csml.Transition {
      to = "smokeAlert"
      iif = Guards.smokeDetectedGuard
      or = "detecting"
    }
  }
}

// FireAlarm state sets the VFireAlarm variable to true and raises a global fireAlarm event
local const fireAlarm: csml.State = new {
  entry {
    new csml.Eval { expression = "\(Vars.vFireAlarm) = true" }
    Actions.aRaiseFireAlarm
  }
  on {
    [Events.eDisarmFireAlarm] = new csml.Transition {
      do {
        new csml.Eval { expression = "\(Vars.vFireAlarm) = false" }
      }
      to = "detecting"
    }
  }
}

// SmokeAlert state sets the vSmokeAlert variable to true and raises a global smokeAlert event
local const smokeAlert: csml.State = new {
  entry {
    new csml.Eval { expression = "\(Vars.vSmokeAlert) = true" }
    Actions.aRaiseSmokeAlert
  }
  on {
    [Events.eDisarmSmokeAlert] = new csml.Transition {
      do {
        new csml.Eval { expression = "\(Vars.vSmokeAlert) = false" }
      }
      to = "detecting"
    }
    // Escalation: If actual fire is detected while in smoke alert
    [Events.eSensorFireDataReceived] = new csml.Transition {
      to = "fireAlarm"
    }
  }
}
