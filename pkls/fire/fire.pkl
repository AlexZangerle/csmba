import "https://raw.githubusercontent.com/CollaborativeStateMachines/Cirrina/refs/heads/develop/src/main/resources/pkl/csm/csml.pkl"
import "../events.pkl" as Events
import "../serviceTypes.pkl" as ServiceTypes
import "../variables.pkl" as Vars
import "actions.pkl" as Actions
import "context.pkl" as Context
import "fireDoor.pkl"
import "guards.pkl" as Guards

// Fire detection state machine definition.
//
// Waits for sensor data, invokes fire detection, and escalates
// to fireAlarm or smokeAlert based on detection results.
// Contains a nested fireDoor state machine.
sm = new csml.StateMachine {
  nested {
    ["fireDoor"] = fireDoor.sm
  }
  transient = Context.fireDetectionContext
  states {
    ["detecting"] = detecting
    ["fireAlarm"] = fireAlarm
    ["smokeAlert"] = smokeAlert
  }
}

local detecting: csml.Initial = new {
  on {
    [Events.eSensorFireDataReceived] {
      yields {
        new csml.Invoke {
          type = ServiceTypes.stDetectFire
          input {
            ["imageData"] = "$imageData"
            ["zoneId"] = "$zoneId"
          }
          emits { new csml.Internal { topic = "detectionDone" } }
        }
      }
    }
    ["detectionDone"] {
      yields {
        new csml.Assign { expression = "\(Vars.vFireDetectionResult) = $fireDetectionResult" }
        new csml.Assign { expression = "\(Vars.vEmergencyInRoom) = $emergencyInRoom" }
        new csml.Match {
          cases {
            new csml.Case {
              of = Guards.fireDetectedGuard
              yields { new csml.Emit { event = new csml.Internal { topic = "goFireAlarm" } } }
            }
            new csml.Case {
              of = Guards.smokeDetectedGuard
              yields { new csml.Emit { event = new csml.Internal { topic = "goSmokeAlert" } } }
            }
          }
        }
      }
    }
    ["goFireAlarm"] { to = "fireAlarm" }
    ["goSmokeAlert"] { to = "smokeAlert" }
  }
}

local fireAlarm: csml.State = new {
  entry {
    new csml.Assign { expression = "\(Vars.vFireAlarm) = true" }
    Actions.aRaiseFireAlarm
  }
  on {
    [Events.eDisarmFireAlarm] {
      to = "detecting"
      yields { new csml.Assign { expression = "\(Vars.vFireAlarm) = false" } }
    }
  }
}

local smokeAlert: csml.State = new {
  entry {
    new csml.Assign { expression = "\(Vars.vSmokeAlert) = true" }
    Actions.aRaiseSmokeAlert
  }
  on {
    [Events.eDisarmSmokeAlert] {
      to = "detecting"
      yields { new csml.Assign { expression = "\(Vars.vSmokeAlert) = false" } }
    }
    [Events.eSensorFireDataReceived] { to = "fireAlarm" }
  }
}
