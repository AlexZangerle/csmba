import
  "https://raw.githubusercontent.com/CollaborativeStateMachines/Cirrina/refs/heads/develop/src/main/resources/pkl/csm/csml.pkl"

import "../variables.pkl" as Vars

// Fire detection state machine definition.
//
// Waits for sensor data, invokes fire detection, and escalates
// to fireAlarm or smokeAlert based on detection results.
sm = new csml.StateMachine {
  transient = new Mapping {
    [Vars.vFireDetectionResult] = "'none'"
    [Vars.vEmergencyInRoom] = "'none'"
  }
  states {
    ["detecting"] = detecting
    ["fireAlarm"] = fireAlarm
    ["smokeAlert"] = smokeAlert
  }
}

local detecting: csml.Initial = new {
  on {
    ["sensorFireDataReceived"] {
      yields {
        new csml.Invoke {
          type = "detectFireService"
          input {
            ["imageData"] = "$imageData"
            ["zoneId"] = "$zoneId"
          }
          emits { new csml.Internal { topic = "detectionDone" } }
        }
      }
    }
    ["detectionDone"] {
      yields {
        new csml.Eval { expression = "\(Vars.vFireDetectionResult) = $fireDetectionResult" }
        new csml.Eval { expression = "\(Vars.vEmergencyInRoom) = $emergencyInRoom" }
        new csml.Match {
          cases {
            new csml.Case {
              of = "\(Vars.vFireDetectionResult) == 'fire'"
              yields { new csml.Emit { event = new csml.Internal { topic = "goFireAlarm" } } }
            }
            new csml.Case {
              of = "\(Vars.vFireDetectionResult) == 'smoke'"
              yields { new csml.Emit { event = new csml.Internal { topic = "goSmokeAlert" } } }
            }
          }
        }
      }
    }
    ["goFireAlarm"] { to = "fireAlarm" }
    ["goSmokeAlert"] { to = "smokeAlert" }
  }
}

local fireAlarm: csml.State = new {
  entry {
    new csml.Eval { expression = "\(Vars.vFireAlarm) = true" }
    new csml.Emit {
      event {
        topic = "fireAlarm"
        data {
          [Vars.vEmergencyInRoom] = Vars.vEmergencyInRoom
        }
      }
    }
  }
  on {
    ["disarmFireAlarm"] {
      to = "detecting"
      yields { new csml.Eval { expression = "\(Vars.vFireAlarm) = false" } }
    }
  }
}

local smokeAlert: csml.State = new {
  entry {
    new csml.Eval { expression = "\(Vars.vSmokeAlert) = true" }
    new csml.Emit { event { topic = "smokeAlert" } }
  }
  on {
    ["disarmSmokeAlert"] {
      to = "detecting"
      yields { new csml.Eval { expression = "\(Vars.vSmokeAlert) = false" } }
    }
    ["sensorFireDataReceived"] {
      yields {
        new csml.Invoke {
          type = "detectFireService"
          input {
            ["imageData"] = "$imageData"
            ["zoneId"] = "$zoneId"
          }
          emits { new csml.Internal { topic = "escalationCheckDone" } }
        }
      }
    }
    ["escalationCheckDone"] {
      yields {
        new csml.Eval { expression = "\(Vars.vFireDetectionResult) = $fireDetectionResult" }
        new csml.Eval { expression = "\(Vars.vEmergencyInRoom) = $emergencyInRoom" }
        new csml.Match {
          cases {
            new csml.Case {
              of = "\(Vars.vFireDetectionResult) == 'fire'"
              yields { new csml.Emit { event = new csml.Internal { topic = "goFireAlarm" } } }
            }
          }
        }
      }
    }
    ["goFireAlarm"] {
      to = "fireAlarm"
      yields { new csml.Eval { expression = "\(Vars.vSmokeAlert) = false" } }
    }
  }
}
