import
  "https://raw.githubusercontent.com/CollaborativeStateMachines/Cirrina/refs/heads/develop/src/main/resources/pkl/csm/csml.pkl"

import "../events.pkl" as Events
import "../serviceTypes.pkl" as ServiceTypes
import "../variables.pkl" as Vars
import "actions.pkl" as Actions
import "context.pkl" as Context
import "guards.pkl" as Guards

// This module contains the definition for the eletricalSafety SM
sm = new csml.StateMachine {
  transient = Context.electricalSafetyContext
  states {
    ["init"] = init
    ["monitoring"] = monitoring
    ["arcFault"] = arcFault
    ["acknowledged"] = acknowledged
    ["gas"] = gas
  }
}

local const init: csml.Initial = new {
  always {
    new csml.Transition { to = "monitoring" }
  }
}

// Always starts in monitoring state
// Invokes service to check for arc faults every 30 seconds
local const monitoring: csml.State = new {
  after {
    ["checkArcFault"] = new csml.Timeout {
      delay = "30000"
      do = Actions.aRaiseStartArcFaultDetection
    }
  }
  on {
    [Events.eStartArcFaultDetection] = new csml.Transition {
      do {
        new csml.Invoke {
          type = ServiceTypes.stCheckArcFault
          raises { new csml.Internal { topic = Events.eArcFaultDetectionComplete } }
        }
      }
    }
    // If an arc fault is found, transition to corresponding state
    [Events.eArcFaultDetectionComplete] = new csml.Transition {
      do {
        new csml.Eval { expression = "\(Vars.vArcFaultLocation) = $arcFaultLocation"}
        new csml.Raise { event = new csml.Internal { topic = Events.eCheckArcFault }}
      }
    }
    [Events.eCheckArcFault] = new csml.Transition {
      to = "arcFault"
      iif = Guards.foundArcFault
    }
  }
}

// If an arc fault is detected, invoke service to trip the corresponding circuit breaker
local const arcFault: csml.State = new {
  entry {
    new csml.Invoke {
      type = ServiceTypes.stTripCircuitBreaker
      input {
        ["arcFaultLocation"] = Vars.vArcFaultLocation
      }
    }
    Actions.aRaiseArcFaultDetected
  }
  on {
    // Transitions to ack state if electrical fault has been manually reset
    [Events.eResetElectricalFault] = new csml.Transition {
      to = "acknowledged"
    }
    // Critical Safety Override
    [Events.eGasLeakDetected] = new csml.Transition {
      to = "gas"
    }
  }
}

// Invokes Ack Service and transitions back to monitoring state
local const acknowledged: csml.State = new {
  entry {
    new csml.Invoke {
      type = ServiceTypes.stAcknowledgedEletrical
    }
  }
  always {
    new csml.Transition {
      to = "monitoring"
    }
  }
}

// Testing purposes / Critical Safety
// Terminal state
local const gas: csml.State = new {
  entry {
    new csml.Invoke {
      type = ServiceTypes.stCutPower
      input {
        ["gasLeakLocation"] = "$gasLeakLocation"
      }
    }
  }
}
