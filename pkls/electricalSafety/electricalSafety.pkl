import "https://raw.githubusercontent.com/CollaborativeStateMachines/Cirrina/refs/heads/develop/src/main/resources/pkl/csm/csml.pkl"
import "../events.pkl" as Events
import "../serviceTypes.pkl" as ServiceTypes
import "../variables.pkl" as Vars
import "actions.pkl" as Actions
import "context.pkl" as Context
import "guards.pkl" as Guards

// Electrical safety state machine definition.
//
// Periodically checks for arc faults every 30s. If detected, trips the
// circuit breaker and waits for manual reset before resuming monitoring.
sm = new csml.StateMachine {
  transient = Context.electricalSafetyContext
  states {
    ["monitoring"] = monitoring
    ["arcFault"] = arcFault
    ["acknowledged"] = acknowledged
  }
}

local monitoring: csml.Initial = new {
  entry {
    new csml.Emit { event = new csml.Internal { topic = "startCheck" } }
  }
  after {
    ["arcFaultPoll"] = new csml.Timeout {
      delay = "30000"
      triggers = new csml.Emit { event = new csml.Internal { topic = "startCheck" } }
    }
  }
  on {
    ["startCheck"] {
      yields {
        new csml.Invoke {
          type = ServiceTypes.stCheckArcFault
          emits { new csml.Internal { topic = "checkDone" } }
        }
      }
    }
    ["checkDone"] {
      yields {
        new csml.Eval { expression = "\(Vars.vArcFaultLocation) = $arcFaultLocation" }
        new csml.Match {
          cases {
            new csml.Case {
              of = Guards.foundArcFault
              yields { new csml.Emit { event = new csml.Internal { topic = "goArcFault" } } }
            }
          }
        }
      }
    }
    ["goArcFault"] { to = "arcFault" }
  }
}

// Trips the breaker and waits for manual reset.
local arcFault: csml.State = new {
  entry {
    new csml.Invoke {
      type = ServiceTypes.stTripCircuitBreaker
      input { ["arcFaultLocation"] = Vars.vArcFaultLocation }
    }
    Actions.aRaiseArcFaultDetected
    new csml.Eval { expression = "\(Vars.vArcFault) = true" }
  }
  on {
    [Events.eResetElectricalFault] { to = "acknowledged" }
  }
}

local acknowledged: csml.State = new {
  entry {
    new csml.Eval { expression = "\(Vars.vArcFault) = false" }
    new csml.Invoke {
      type = ServiceTypes.stAcknowledgedEletrical
      emits { new csml.Internal { topic = "ackComplete" } }
    }
  }
  on {
    ["ackComplete"] { to = "monitoring" }
  }
}
