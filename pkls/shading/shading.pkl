import
  "https://raw.githubusercontent.com/CollaborativeStateMachines/Cirrina/refs/heads/develop/src/main/resources/pkl/csm/csml.pkl"

import "../variables.pkl" as Vars

// Shading (blinds) state machine definition.
sm = new csml.StateMachine {
  transient = new Mapping {
    [Vars.vIsLocked] = "false"
    [Vars.vOutdoorTemp] = "'0'"
  }
  states {
    ["half"] = half
    ["fullyOpen"] = fullyOpen
    ["close"] = close
    ["userLevel"] = userLevel
    ["emergency"] = emergency
  }
}

local half: csml.Initial = new {
  entry {
    new csml.Invoke {
      type = "blindsHalfService"
      input { ["roomId"] = Vars.vRoomId }
    }
  }
  after {
    ["tempPoll"] = new csml.Timeout {
      delay = "60000"
      triggers = new csml.Emit { event = new csml.Internal { topic = "startOutdoorCheck" } }
    }
  }
  on {
    ["startOutdoorCheck"] {
      yields {
        new csml.Invoke {
          type = "getOutdoorTempService"
          emits { new csml.Internal { topic = "outdoorCheckDone" } }
        }
      }
    }
    ["outdoorCheckDone"] {
      provided = "\(Vars.vIsLocked) == false"
      yields {
        new csml.Eval { expression = "\(Vars.vOutdoorTemp) = $outdoorTemp" }
        new csml.Match {
          cases {
            new csml.Case {
              of = "\(Vars.vOutdoorTemp) < 15"
              yields { new csml.Emit { event = new csml.Internal { topic = "goFullyOpen" } } }
            }
            new csml.Case {
              of = "\(Vars.vOutdoorTemp) >= 22"
              yields { new csml.Emit { event = new csml.Internal { topic = "goClose" } } }
            }
          }
        }
      }
    }
    ["goFullyOpen"] { to = "fullyOpen" }
    ["goClose"] { to = "close" }

    ["userLevelBlinds"] { to = "userLevel" }
    ["lockBlinds"] { yields { new csml.Eval { expression = "\(Vars.vIsLocked) = true" } } }
    ["unlockBlinds"] { yields { new csml.Eval { expression = "\(Vars.vIsLocked) = false" } } }

    ["zoneInactive"] { to = "close" }
    ["lockdownZone"] { to = "close" }

    ["fireAlarm"] { to = "emergency" }
    ["smokeAlert"] { to = "emergency" }
    ["gasLeakDetected"] { to = "emergency" }
    ["arcFaultDetected"] { to = "emergency" }
  }
}

local fullyOpen: csml.State = new {
  entry {
    new csml.Invoke {
      type = "blindsOpenService"
      input { ["roomId"] = Vars.vRoomId }
    }
  }
  after {
    ["tempPoll"] = new csml.Timeout {
      delay = "60000"
      triggers = new csml.Emit { event = new csml.Internal { topic = "startOutdoorCheck" } }
    }
  }
  on {
    ["startOutdoorCheck"] {
      yields {
        new csml.Invoke {
          type = "getOutdoorTempService"
          emits { new csml.Internal { topic = "outdoorCheckDone" } }
        }
      }
    }
    ["outdoorCheckDone"] {
      provided = "\(Vars.vIsLocked) == false"
      yields {
        new csml.Eval { expression = "\(Vars.vOutdoorTemp) = $outdoorTemp" }
        new csml.Match {
          cases {
            new csml.Case {
              of = "\(Vars.vOutdoorTemp) >= 15 && \(Vars.vOutdoorTemp) < 22"
              yields { new csml.Emit { event = new csml.Internal { topic = "goHalf" } } }
            }
            new csml.Case {
              of = "\(Vars.vOutdoorTemp) >= 22"
              yields { new csml.Emit { event = new csml.Internal { topic = "goClose" } } }
            }
          }
        }
      }
    }
    ["goHalf"] { to = "half" }
    ["goClose"] { to = "close" }

    ["userLevelBlinds"] { to = "userLevel" }
    ["lockBlinds"] { yields { new csml.Eval { expression = "\(Vars.vIsLocked) = true" } } }
    ["unlockBlinds"] { yields { new csml.Eval { expression = "\(Vars.vIsLocked) = false" } } }
    ["zoneInactive"] { to = "close" }
    ["lockdownZone"] { to = "close" }
    ["fireAlarm"] { to = "emergency" }
    ["smokeAlert"] { to = "emergency" }
    ["gasLeakDetected"] { to = "emergency" }
    ["arcFaultDetected"] { to = "emergency" }
  }
}

local close: csml.State = new {
  entry {
    new csml.Invoke {
      type = "blindCloseService"
      input { ["roomId"] = Vars.vRoomId }
    }
  }
  after {
    ["tempPoll"] = new csml.Timeout {
      delay = "60000"
      triggers = new csml.Emit { event = new csml.Internal { topic = "startOutdoorCheck" } }
    }
  }
  on {
    ["startOutdoorCheck"] {
      yields {
        new csml.Invoke {
          type = "getOutdoorTempService"
          emits { new csml.Internal { topic = "outdoorCheckDone" } }
        }
      }
    }
    ["outdoorCheckDone"] {
      provided = "\(Vars.vIsLocked) == false"
      yields {
        new csml.Eval { expression = "\(Vars.vOutdoorTemp) = $outdoorTemp" }
        new csml.Match {
          cases {
            new csml.Case {
              of = "\(Vars.vOutdoorTemp) < 15"
              yields { new csml.Emit { event = new csml.Internal { topic = "goFullyOpen" } } }
            }
            new csml.Case {
              of = "\(Vars.vOutdoorTemp) >= 15 && \(Vars.vOutdoorTemp) < 22"
              yields { new csml.Emit { event = new csml.Internal { topic = "goHalf" } } }
            }
          }
        }
      }
    }
    ["goFullyOpen"] { to = "fullyOpen" }
    ["goHalf"] { to = "half" }

    ["userLevelBlinds"] { to = "userLevel" }
    ["lockBlinds"] { yields { new csml.Eval { expression = "\(Vars.vIsLocked) = true" } } }
    ["unlockBlinds"] { yields { new csml.Eval { expression = "\(Vars.vIsLocked) = false" } } }

    ["zoneActive"] { to = "half" }
    ["clearSecurityAlert"] { to = "half" }

    ["fireAlarm"] { to = "emergency" }
    ["smokeAlert"] { to = "emergency" }
    ["gasLeakDetected"] { to = "emergency" }
    ["arcFaultDetected"] { to = "emergency" }
  }
}

local userLevel: csml.State = new {
  static { [Vars.vUserBlindLevel] = "0" }
  entry {
    new csml.Eval {
      expression =
        "\(Vars.vUserBlindLevel) == (($blindLevel == -1) ? \(Vars.vUserBlindLevel) : $blindLevel)"
    }
    new csml.Invoke {
      type = "blindsUserLevelService"
      input { ["blindLevel"] = Vars.vUserBlindLevel; ["roomId"] = Vars.vRoomId }
    }
    new csml.Invoke {
      type = "getOutdoorTempService"
      emits { new csml.Internal { topic = "outdoorCheckDone" } }
    }
  }
  after {
    ["tempPoll"] = new csml.Timeout {
      delay = "60000"
      triggers = new csml.Emit { event = new csml.Internal { topic = "startOutdoorCheck" } }
    }
  }
  on {
    ["startOutdoorCheck"] {
      yields {
        new csml.Invoke {
          type = "getOutdoorTempService"
          emits { new csml.Internal { topic = "outdoorCheckDone" } }
        }
      }
    }
    ["outdoorCheckDone"] {
      yields { new csml.Eval { expression = "\(Vars.vOutdoorTemp) = $outdoorTemp" } }
    }
    ["deactivateUserLevelBlinds"] {
      yields {
        new csml.Match {
          cases {
            new csml.Case {
              of = "\(Vars.vOutdoorTemp) < 15"
              yields { new csml.Emit { event = new csml.Internal { topic = "goFullyOpen" } } }
            }
            new csml.Case {
              of = "\(Vars.vOutdoorTemp) >= 22"
              yields { new csml.Emit { event = new csml.Internal { topic = "goClose" } } }
            }
          }
          default = new csml.Emit { event = new csml.Internal { topic = "goHalf" } }
        }
      }
    }
    ["goFullyOpen"] { to = "fullyOpen" }
    ["goClose"] { to = "close" }
    ["goHalf"] { to = "half" }

    ["lockBlinds"] { yields { new csml.Eval { expression = "\(Vars.vIsLocked) = true" } } }
    ["unlockBlinds"] { yields { new csml.Eval { expression = "\(Vars.vIsLocked) = false" } } }

    ["zoneInactive"] { to = "close" }
    ["lockdownZone"] { to = "close" }

    ["fireAlarm"] { to = "emergency" }
    ["smokeAlert"] { to = "emergency" }
    ["gasLeakDetected"] { to = "emergency" }
    ["arcFaultDetected"] { to = "emergency" }
  }
}

local emergency: csml.State = new {
  entry {
    new csml.Invoke {
      type = "blindsUserLevelService"
      input { ["blindLevel"] = "100"; ["roomId"] = Vars.vRoomId }
    }
  }
  on {
    ["disarmFireAlarm"] {
      to = "half"
      provided =
        "!\(Vars.vFireAlarm) && !\(Vars.vGasActive) && !\(Vars.vSmokeAlert) && !\(Vars.vArcFault)"
    }
    ["gasPurged"] {
      to = "half"
      provided =
        "!\(Vars.vFireAlarm) && !\(Vars.vGasActive) && !\(Vars.vSmokeAlert) && !\(Vars.vArcFault)"
    }
    ["disarmSmokeAlert"] {
      to = "half"
      provided =
        "!\(Vars.vFireAlarm) && !\(Vars.vGasActive) && !\(Vars.vSmokeAlert) && !\(Vars.vArcFault)"
    }
    ["electricalReset"] {
      to = "half"
      provided =
        "!\(Vars.vFireAlarm) && !\(Vars.vGasActive) && !\(Vars.vSmokeAlert) && !\(Vars.vArcFault)"
    }
  }
}
