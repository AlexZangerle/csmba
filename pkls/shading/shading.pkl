import "https://raw.githubusercontent.com/CollaborativeStateMachines/Cirrina/refs/heads/develop/src/main/resources/pkl/csm/csml.pkl"
import "../events.pkl" as Events
import "../serviceTypes.pkl" as ServiceTypes
import "../variables.pkl" as Vars
import "actions.pkl" as Actions
import "context.pkl" as Context
import "guards.pkl" as Guards

// Shading (blinds) state machine definition.
sm = new csml.StateMachine {
  transient = Context.blindLockContext
  states {
    ["half"] = half
    ["fullyOpen"] = fullyOpen
    ["close"] = close
    ["userLevel"] = userLevel
    ["emergency"] = emergency
  }
}

local half: csml.Initial = new {
  entry {
    new csml.Invoke {
      type = ServiceTypes.stBlindsHalf
      input { ["roomId"] = Vars.vRoomId }
    }
  }
  after {
    ["tempPoll"] = new csml.Timeout {
      delay = "60000"
      triggers = new csml.Emit { event = new csml.Internal { topic = "startOutdoorCheck" } }
    }
  }
  on {
    ["startOutdoorCheck"] {
      yields {
        new csml.Invoke {
          type = ServiceTypes.stGetOutdoorTemp
          emits { new csml.Internal { topic = "outdoorCheckDone" } }
        }
      }
    }
    ["outdoorCheckDone"] {
      provided = Guards.isLockedGuard
      yields {
        new csml.Eval { expression = "\(Vars.vOutdoorTemp) = $outdoorTemp" }
        new csml.Match {
          cases {
            new csml.Case {
              of = Guards.isColdGuard
              yields { new csml.Emit { event = new csml.Internal { topic = "goFullyOpen" } } }
            }
            new csml.Case {
              of = Guards.isHotGuard
              yields { new csml.Emit { event = new csml.Internal { topic = "goClose" } } }
            }
          }
        }
      }
    }
    ["goFullyOpen"] { to = "fullyOpen" }
    ["goClose"] { to = "close" }

    [Events.eActivateBlindsUserLevel] {
      to = "userLevel"
      yields { new csml.Eval { expression = "\(Vars.vUserBlindLevel) = $blindLevel" } }
    }
    [Events.eLockBlinds] { yields { Actions.aBlindLock } }
    [Events.eUnlockBlinds] { yields { Actions.aBlindUnlock } }

    [Events.eZoneInactive] { to = "close"; }
    [Events.eLockdownZone] { to = "close"; }

    [Events.eFireAlarm] { to = "emergency" }
    [Events.eSmokeAlert] { to = "emergency" }
    [Events.eGasLeakDetected] { to = "emergency" }
    [Events.eArcFaultDetected] { to = "emergency" }
  }
}

local fullyOpen: csml.State = new {
  entry {
    new csml.Invoke {
      type = ServiceTypes.stBlindsOpen
      input { ["roomId"] = Vars.vRoomId }
    }
  }
  after {
    ["tempPoll"] = new csml.Timeout {
      delay = "60000"
      triggers = new csml.Emit { event = new csml.Internal { topic = "startOutdoorCheck" } }
    }
  }
  on {
    ["startOutdoorCheck"] {
      yields {
        new csml.Invoke {
          type = ServiceTypes.stGetOutdoorTemp
          emits { new csml.Internal { topic = "outdoorCheckDone" } }
        }
      }
    }
    ["outdoorCheckDone"] {
      provided = Guards.isLockedGuard
      yields {
        new csml.Eval { expression = "\(Vars.vOutdoorTemp) = $outdoorTemp" }
        new csml.Match {
          cases {
            new csml.Case {
              of = Guards.isMediumGuard
              yields { new csml.Emit { event = new csml.Internal { topic = "goHalf" } } }
            }
            new csml.Case {
              of = Guards.isHotGuard
              yields { new csml.Emit { event = new csml.Internal { topic = "goClose" } } }
            }
          }
        }
      }
    }
    ["goHalf"] { to = "half" }
    ["goClose"] { to = "close" }

    [Events.eActivateBlindsUserLevel] {
      to = "userLevel"
      yields { new csml.Eval { expression = "\(Vars.vUserBlindLevel) = $blindLevel" } }
    }
    [Events.eLockBlinds] { yields { Actions.aBlindLock } }
    [Events.eUnlockBlinds] { yields { Actions.aBlindUnlock } }
    [Events.eZoneInactive] { to = "close"; }
    [Events.eLockdownZone] { to = "close"; }
    [Events.eFireAlarm] { to = "emergency" }
    [Events.eSmokeAlert] { to = "emergency" }
    [Events.eGasLeakDetected] { to = "emergency" }
    [Events.eArcFaultDetected] { to = "emergency" }
  }
}

local close: csml.State = new {
  entry {
    new csml.Invoke {
      type = ServiceTypes.stBlindsClose
      input { ["roomId"] = Vars.vRoomId }
    }
  }
  after {
    ["tempPoll"] = new csml.Timeout {
      delay = "60000"
      triggers = new csml.Emit { event = new csml.Internal { topic = "startOutdoorCheck" } }
    }
  }
  on {
    ["startOutdoorCheck"] {
      yields {
        new csml.Invoke {
          type = ServiceTypes.stGetOutdoorTemp
          emits { new csml.Internal { topic = "outdoorCheckDone" } }
        }
      }
    }
    ["outdoorCheckDone"] {
      provided = Guards.isLockedGuard
      yields {
        new csml.Eval { expression = "\(Vars.vOutdoorTemp) = $outdoorTemp" }
        new csml.Match {
          cases {
            new csml.Case {
              of = Guards.isColdGuard
              yields { new csml.Emit { event = new csml.Internal { topic = "goFullyOpen" } } }
            }
            new csml.Case {
              of = Guards.isMediumGuard
              yields { new csml.Emit { event = new csml.Internal { topic = "goHalf" } } }
            }
          }
        }
      }
    }
    ["goFullyOpen"] { to = "fullyOpen" }
    ["goHalf"] { to = "half" }

    [Events.eActivateBlindsUserLevel] {
      to = "userLevel"
      yields { new csml.Eval { expression = "\(Vars.vUserBlindLevel) = $blindLevel" } }
    }
    [Events.eLockBlinds] { yields { Actions.aBlindLock } }
    [Events.eUnlockBlinds] { yields { Actions.aBlindUnlock } }

    [Events.eZoneActive] { to = "half"; }
    [Events.eClearSecurityAlert] { to = "half"; }

    [Events.eFireAlarm] { to = "emergency" }
    [Events.eSmokeAlert] { to = "emergency" }
    [Events.eGasLeakDetected] { to = "emergency" }
    [Events.eArcFaultDetected] { to = "emergency" }
  }
}

local userLevel: csml.State = new {
  static { [Vars.vUserBlindLevel] = "'0'" }
  entry {
    new csml.Invoke {
      type = ServiceTypes.stBlindsUserLevel
      input { ["blindLevel"] = Vars.vUserBlindLevel; ["roomId"] = Vars.vRoomId }
    }
    new csml.Invoke {
      type = ServiceTypes.stGetOutdoorTemp
      emits { new csml.Internal { topic = "outdoorCheckDone" } }
    }
  }
  after {
    ["tempPoll"] = new csml.Timeout {
      delay = "60000"
      triggers = new csml.Emit { event = new csml.Internal { topic = "startOutdoorCheck" } }
    }
  }
  on {
    ["startOutdoorCheck"] {
      yields {
        new csml.Invoke {
          type = ServiceTypes.stGetOutdoorTemp
          emits { new csml.Internal { topic = "outdoorCheckDone" } }
        }
      }
    }
    ["outdoorCheckDone"] {
      yields { new csml.Eval { expression = "\(Vars.vOutdoorTemp) = $outdoorTemp" } }
    }
    [Events.eDeactivateBlindsUserLevel] {
      yields {
        new csml.Match {
          cases {
            new csml.Case {
              of = Guards.isColdGuard
              yields { new csml.Emit { event = new csml.Internal { topic = "goFullyOpen" } } }
            }
            new csml.Case {
              of = Guards.isHotGuard
              yields { new csml.Emit { event = new csml.Internal { topic = "goClose" } } }
            }
          }
          default = new csml.Emit { event = new csml.Internal { topic = "goHalf" } }
        }
      }
    }
    ["goFullyOpen"] { to = "fullyOpen" }
    ["goClose"] { to = "close" }
    ["goHalf"] { to = "half" }

    [Events.eLockBlinds] { yields { Actions.aBlindLock } }
    [Events.eUnlockBlinds] { yields { Actions.aBlindUnlock } }

    [Events.eZoneInactive] { to = "close"; }
    [Events.eLockdownZone] { to = "close"; }

    [Events.eFireAlarm] { to = "emergency" }
    [Events.eSmokeAlert] { to = "emergency" }
    [Events.eGasLeakDetected] { to = "emergency" }
    [Events.eArcFaultDetected] { to = "emergency" }
  }
}

local emergency: csml.State = new {
  entry {
    new csml.Invoke {
      type = ServiceTypes.stBlindsUserLevel
      input { ["blindLevel"] = "'100'"; ["roomId"] = Vars.vRoomId }
    }
  }
  on {
    [Events.eDisarmFireAlarm] {
      to = "half"
      provided = Guards.isSafeToExitEmergency
    }
    [Events.eGasPurged] {
      to = "half"
      provided = Guards.isSafeToExitEmergency
    }
    [Events.eDisarmSmokeAlert] {
      to = "half"
      provided = Guards.isSafeToExitEmergency
    }
    [Events.eResetElectricalFault] {
      to = "half"
      provided = Guards.isSafeToExitEmergency
    }
  }
}
