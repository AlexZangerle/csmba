import
  "https://raw.githubusercontent.com/CollaborativeStateMachines/Cirrina/refs/heads/develop/src/main/resources/pkl/csm/csml.pkl"

import "../events.pkl" as Events
import "../serviceTypes.pkl" as ServiceTypes
import "../variables.pkl" as Vars
import "actions.pkl" as Actions
import "context.pkl" as Context
import "guards.pkl" as Guards

// This module contains the definition for the shadingSM
sm = new csml.StateMachine {
  transient = Context.blindLockContext
  states {
    ["init"] = init
    ["half"] = half
    ["halfLoop"] = halfLoop
    ["fullyOpen"] = fullyOpen
    ["fullyOpenLoop"] = fullyOpenLoop
    ["close"] = close
    ["closeLoop"] = closeLoop
    ["userLevel"] = userLevel
    ["userLevelLoop"] = userLevelLoop
    ["emergency"] = emergency
    // Helper logic states
    ["checkCold"] = checkCold
    ["checkHot"] = checkHot
    ["checkColdOpen"] = checkColdOpen
    ["checkHotOpen"] = checkHotOpen
    ["checkColdClose"] = checkColdClose
    ["checkHotClose"] = checkHotClose
    ["checkUserDeactivation"] = checkUserDeactivation
    ["checkUserDeactivationHot"] = checkUserDeactivationHot
  }
}

local const init: csml.Initial = new {
  always {
    new csml.Transition { to = "half" }
  }
}

// -------------------- HALF OPEN --------------------

local const half: csml.State = new {
  entry {
    new csml.Invoke {
      type = ServiceTypes.stBlindsHalf
      // Explicitly raise completion to unblock
      raises { new csml.Internal { topic = "blindsMoved" } }
    }
  }
  on {
    // Wait for blinds to finish moving before entering loop
    ["blindsMoved"] = new csml.Transition { to = "halfLoop" }
  }
}

local const halfLoop: csml.State = new {
  after {
    ["detectOutsideTemp"] = new csml.Timeout {
      delay = "60000"
      // Raises INTERNAL event, ensuring no conflict with Occupancy
      do = new csml.Raise { event = new csml.Internal { topic = "startOutdoorCheck" } }
    }
  }
  on {
    // Listen for the local internal event
    ["startOutdoorCheck"] = new csml.Transition {
      do {
        new csml.Invoke {
          type = ServiceTypes.stGetOutdoorTemp
          raises { new csml.Internal { topic = Events.eOutsideDetectionComplete } }
        }
      }
    }
    // 1. Assign Data
    [Events.eOutsideDetectionComplete] = new csml.Transition {
      do {
        new csml.Eval { expression = "\(Vars.vOutdoorTemp) = $outdoorTemp" }
        new csml.Raise { event = new csml.Internal { topic = "processTemp" } }
      }
    }
    // 2. Logic Check
    ["processTemp"] = new csml.Transition {
      to = "checkCold"
      iif = Guards.isLockedGuard
      or = "halfLoop" // Stay if locked
    }

    // External Events
    [Events.eActivateBlindsUserLevel] = new csml.Transition {
      to = "userLevel"
      do { new csml.Eval { expression = "\(Vars.vUserBlindLevel) = $blindLevel" } }
    }
    [Events.eLockBlinds] = new csml.Transition { do { Actions.aBlindLock } }
    [Events.eUnlockBlinds] = new csml.Transition { do { Actions.aBlindUnlock } }

    [Events.eZoneInactive] = new csml.Transition { to = "close"; iif = Guards.isMyZone }
    [Events.eLockdownZone] = new csml.Transition { to = "close"; iif = Guards.isMyZone }

    [Events.eFireAlarm] = new csml.Transition { to = "emergency" }
    [Events.eSmokeAlert] = new csml.Transition { to = "emergency" }
    [Events.eGasLeakDetected] = new csml.Transition { to = "emergency" }
  }
}

// Logic: Half -> Cold? -> Hot?
local const checkCold: csml.State = new {
  always {
    new csml.Transition {
      to = "fullyOpen"
      iif = Guards.isColdGuard
      or = "checkHot"
    }
  }
}
local const checkHot: csml.State = new {
  always {
    new csml.Transition {
      to = "close"
      iif = Guards.isHotGuard
      or = "halfLoop" // Stay at half
    }
  }
}

// -------------------- FULLY OPEN --------------------

local const fullyOpen: csml.State = new {
  entry {
    new csml.Invoke {
      type = ServiceTypes.stBlindsOpen
      raises { new csml.Internal { topic = "blindsMoved" } }
    }
  }
  on {
    ["blindsMoved"] = new csml.Transition { to = "fullyOpenLoop" }
  }
}

local const fullyOpenLoop: csml.State = new {
  after {
    ["detectOutsideTemp"] = new csml.Timeout {
      delay = "60000"
      do = new csml.Raise { event = new csml.Internal { topic = "startOutdoorCheck" } }
    }
  }
  on {
    ["startOutdoorCheck"] = new csml.Transition {
      do {
        new csml.Invoke {
          type = ServiceTypes.stGetOutdoorTemp
          raises { new csml.Internal { topic = Events.eOutsideDetectionComplete } }
        }
      }
    }
    [Events.eOutsideDetectionComplete] = new csml.Transition {
      do {
        new csml.Eval { expression = "\(Vars.vOutdoorTemp) = $outdoorTemp" }
        new csml.Raise { event = new csml.Internal { topic = "processTemp" } }
      }
    }
    ["processTemp"] = new csml.Transition {
      to = "checkColdOpen"
      iif = Guards.isLockedGuard
      or = "fullyOpenLoop"
    }

    [Events.eActivateBlindsUserLevel] = new csml.Transition {
      to = "userLevel"
      do { new csml.Eval { expression = "\(Vars.vUserBlindLevel) = $blindLevel" } }
    }
    [Events.eLockBlinds] = new csml.Transition { do { Actions.aBlindLock } }
    [Events.eUnlockBlinds] = new csml.Transition { do { Actions.aBlindUnlock } }

    [Events.eZoneInactive] = new csml.Transition { to = "close"; iif = Guards.isMyZone }
    [Events.eLockdownZone] = new csml.Transition { to = "close"; iif = Guards.isMyZone }

    [Events.eFireAlarm] = new csml.Transition { to = "emergency" }
    [Events.eSmokeAlert] = new csml.Transition { to = "emergency" }
    [Events.eGasLeakDetected] = new csml.Transition { to = "emergency" }
  }
}

// Logic: Open -> Medium? -> Hot?
local const checkColdOpen: csml.State = new {
  always {
    new csml.Transition {
      to = "half"
      iif = Guards.isMediumGuard
      or = "checkHotOpen"
    }
  }
}
local const checkHotOpen: csml.State = new {
  always {
    new csml.Transition {
      to = "close"
      iif = Guards.isHotGuard
      or = "fullyOpenLoop" // Stay open
    }
  }
}

// -------------------- CLOSE --------------------

local const close: csml.State = new {
  entry {
    new csml.Invoke {
      type = ServiceTypes.stBlindsClose
      raises { new csml.Internal { topic = "blindsMoved" } }
    }
  }
  on {
    ["blindsMoved"] = new csml.Transition { to = "closeLoop" }
  }
}

local const closeLoop: csml.State = new {
  after {
    ["detectOutsideTemp"] = new csml.Timeout {
      delay = "60000"
      do = new csml.Raise { event = new csml.Internal { topic = "startOutdoorCheck" } }
    }
  }
  on {
    ["startOutdoorCheck"] = new csml.Transition {
      do {
        new csml.Invoke {
          type = ServiceTypes.stGetOutdoorTemp
          raises { new csml.Internal { topic = Events.eOutsideDetectionComplete } }
        }
      }
    }
    [Events.eOutsideDetectionComplete] = new csml.Transition {
      do {
        new csml.Eval { expression = "\(Vars.vOutdoorTemp) = $outdoorTemp" }
        new csml.Raise { event = new csml.Internal { topic = "processTemp" } }
      }
    }
    ["processTemp"] = new csml.Transition {
      to = "checkColdClose"
      iif = Guards.isLockedGuard
      or = "closeLoop"
    }

    [Events.eActivateBlindsUserLevel] = new csml.Transition {
      to = "userLevel"
      do { new csml.Eval { expression = "\(Vars.vUserBlindLevel) = $blindLevel" } }
    }
    [Events.eLockBlinds] = new csml.Transition { do { Actions.aBlindLock } }
    [Events.eUnlockBlinds] = new csml.Transition { do { Actions.aBlindUnlock } }

    [Events.eZoneActive] = new csml.Transition { to = "half"; iif = Guards.isMyZone }
    [Events.eClearSecurityAlert] = new csml.Transition { to = "half"; iif = Guards.isMyZone }

    [Events.eFireAlarm] = new csml.Transition { to = "emergency" }
    [Events.eSmokeAlert] = new csml.Transition { to = "emergency" }
    [Events.eGasLeakDetected] = new csml.Transition { to = "emergency" }
  }
}

// Logic: Close -> Medium? -> Cold?
local const checkColdClose: csml.State = new {
  always {
    new csml.Transition {
      to = "half"
      iif = Guards.isMediumGuard
      or = "checkHotClose"
    }
  }
}
local const checkHotClose: csml.State = new {
  always {
    new csml.Transition {
      to = "fullyOpen"
      iif = Guards.isColdGuard
      or = "closeLoop" // Stay closed
    }
  }
}

// -------------------- USER LEVEL --------------------

local const userLevel: csml.State = new {
  static {
    [Vars.vUserBlindLevel] = "'0'"
  }
  entry {
    new csml.Invoke {
      type = ServiceTypes.stBlindsUserLevel
      input { ["blindLevel"] = Vars.vUserBlindLevel }
      raises { new csml.Internal { topic = "blindsMoved" } }
    }
  }
  on {
    ["blindsMoved"] = new csml.Transition { to = "userLevelLoop" }
  }
}

local const userLevelLoop: csml.State = new {
  entry {
    new csml.Raise { event = new csml.Internal { topic = "startOutdoorCheck" } }
  }
  after {
    ["detectOutsideTemp"] = new csml.Timeout {
      delay = "60000"
      do = new csml.Raise { event = new csml.Internal { topic = "startOutdoorCheck" } }
    }
  }
  on {
    // Only updating data for background monitoring, not auto-transitioning
    ["startOutdoorCheck"] = new csml.Transition {
      do {
        new csml.Invoke {
          type = ServiceTypes.stGetOutdoorTemp
          raises { new csml.Internal { topic = Events.eOutsideDetectionComplete } }
        }
      }
    }
    [Events.eOutsideDetectionComplete] = new csml.Transition {
      do { new csml.Eval { expression = "\(Vars.vOutdoorTemp) = $outdoorTemp" } }
    }

    [Events.eLockBlinds] = new csml.Transition { do { Actions.aBlindLock } }
    [Events.eUnlockBlinds] = new csml.Transition { do { Actions.aBlindUnlock } }

    // Deactivation -> Check Temp to decide where to go
    [Events.eDeactivateBlindsUserLevel] = new csml.Transition { to = "checkUserDeactivation" }

    [Events.eZoneInactive] = new csml.Transition { to = "close"; iif = Guards.isMyZone }
    [Events.eLockdownZone] = new csml.Transition { to = "close"; iif = Guards.isMyZone }

    [Events.eFireAlarm] = new csml.Transition { to = "emergency" }
    [Events.eSmokeAlert] = new csml.Transition { to = "emergency" }
    [Events.eGasLeakDetected] = new csml.Transition { to = "emergency" }
  }
}

local const checkUserDeactivation: csml.State = new {
  always {
    new csml.Transition {
      to = "fullyOpen"
      iif = Guards.isColdGuard
      or = "checkUserDeactivationHot"
    }
  }
}
local const checkUserDeactivationHot: csml.State = new {
  always {
    new csml.Transition {
      to = "close"
      iif = Guards.isHotGuard
      or = "half" // Default: Medium
    }
  }
}

// -------------------- EMERGENCY --------------------

local const emergency: csml.State = new {
  entry {
    new csml.Invoke {
      type = ServiceTypes.stBlindsUserLevel
      input { ["blindLevel"] = "'100'" }
      raises { new csml.Internal { topic = "emergencyBlindsComplete" } }
    }
  }
  on {
    [Events.eDisarmFireAlarm] = new csml.Transition { to = "half" }
    [Events.eGasPurged] = new csml.Transition { to = "half" }
  }
}
