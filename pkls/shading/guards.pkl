import "../variables.pkl" as Vars
import "https://raw.githubusercontent.com/CollaborativeStateMachines/Cirrina/refs/heads/develop/src/main/resources/pkl/csm/csml.pkl"

// This module contains all guards for shading SM

// Guard to check if blinds are locked
isLockedGuard = "\(Vars.vIsLocked) == false"


// Guards to determine if the current temperature is hot/medium/cold
isHotGuard = "\(Vars.vOutdoorTemp) >= 22"


isMediumGuard = "\(Vars.vOutdoorTemp) >= 15 && \(Vars.vOutdoorTemp) < 22"


isColdGuard = "\(Vars.vOutdoorTemp) < 15"

// Guards to determine if there currently is a fire alarm / smoke alert
noFireAlarm = "!\(Vars.vFireAlarm)"


noSmokeAlert = "!\(Vars.vSmokeAlert)"


isMyZone = "$zoneId == \(Vars.vZoneId)"
