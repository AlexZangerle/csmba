import "https://raw.githubusercontent.com/CollaborativeStateMachines/Cirrina/refs/heads/develop/src/main/resources/pkl/csm/csml.pkl"
import "../events.pkl"
import "../variables.pkl" as Vars
// This module contains actions for the shading SM

aBlindLock = new csml.Eval {
  expression = "\(Vars.vIsLocked) = true"
}

aBlindUnlock = new csml.Eval {
  expression = "\(Vars.vIsLocked) = false"
}

aRaiseDetectOutsideTemp = new csml.Emit {
  event = new csml.Internal {
    topic = events.eStartDetectingOutsideTemp
  }
}
