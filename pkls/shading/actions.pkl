import "https://raw.githubusercontent.com/AlexZangerle/csmba/main/pkls/variables.pkl" as Vars
import "https://raw.githubusercontent.com/CollaborativeStateMachines/Cirrina/refs/heads/develop/src/main/resources/pkl/csm/Csml.pkl"
import "../events.pkl"
// This module contains actions for the shading SM

aBlindLock = new Csml.AssignActionDescription {
  variable {
    name = Vars.vIsLocked
    value = "true"
  }
}

aBlindUnlock = new Csml.AssignActionDescription {
  variable {
    name = Vars.vIsLocked
    value = "false"
  }
}

aRaiseDetectOutsideTemp = new Csml.RaiseActionDescription {
  event {
    name = events.eStartDetectingOutsideTemp
    channel = "internal"
  }
}
