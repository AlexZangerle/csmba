import "https://raw.githubusercontent.com/CollaborativeStateMachines/Cirrina/refs/heads/develop/src/main/resources/pkl/csm/csml.pkl"
import "../events.pkl" as Events
// This module contains actions for the room occupancy SM

// Raise action to start detecting occupancy
aRaiseStartDetectingOccupancy = new csml.Emit {
  event = new csml.Internal {
    topic = Events.eStartDetectingOccupancy
  }
}

// Raise action when occupancy detection results in occupied
aRaiseOccupancyDetected = new csml.Emit {
  event {
    topic = Events.eOccupancyDetected
  }
}

// Raise action when occupancy detection results in vacant
aRaiseOccupancyVacant = new csml.Emit {
  event {
    topic = Events.eOccupancyVacant
  }
}

// Raise action when occupancy detection results in transient
aRaiseOccupancyTransient = new csml.Emit {
  event {
    topic = Events.eOccupancyTransient
  }
}

// Raise action when occupancy detection took unusually long
aRaiseMaintenance = new csml.Emit {
  event {
    topic = Events.eMaintenanceRequired
  }
}

aRaiseStartGasLeakDetection = new csml.Emit {
  event = new csml.Internal {
    topic = Events.eStartGasLeakDetection
  }
}
