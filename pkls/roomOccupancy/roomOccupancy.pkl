import "https://raw.githubusercontent.com/CollaborativeStateMachines/Cirrina/refs/heads/develop/src/main/resources/pkl/csm/csml.pkl"
import "../events.pkl" as Events
import "../serviceTypes.pkl" as ServiceTypes
import "../variables.pkl" as Vars
import "actions.pkl" as Actions
import "context.pkl" as Context
import "guards.pkl" as Guards
import "occupancyMonitor.pkl"

// Room occupancy state machine definition.
//
// Listens for sensor data, invokes an occupancy detection service,
// and transitions between vacant -> occupied -> transient based on results.
sm = new csml.StateMachine {
  transient = Context.occupancyLocalContext
  nested {
    ["occupancyMonitor"] = occupancyMonitor.sm
  }
  states {
    ["vacant"] = vacant
    ["occupied"] = occupied
    ["transient"] = transientState
  }
}

local vacant: csml.Initial = new {
  entry {
    new csml.Eval { expression = "\(Vars.vCurrentOccupancy) = 'vacant'" }
  }
  on {
    ["sensorOccupancyReceived"] {

      yields {
        new csml.Invoke {
          type = ServiceTypes.stDetectOccupancy
          input { ["imageData"] = "$imageData" }
          emits { new csml.Internal { topic = "detectionDone" } }
        }
      }
    }
    ["detectionDone"] {
      yields {
        new csml.Eval { expression = "\(Vars.vOccupancyDetected) = $occupancyDetected" }
        new csml.Match {
          cases {
            new csml.Case {
              of = Guards.occupancyDetected
              yields { new csml.Emit { event = new csml.Internal { topic = "goOccupied" } } }
            }
          }
        }
      }
    }
    ["goOccupied"] {
      to = "occupied"
      yields { Actions.aRaiseOccupancyDetected }
    }
  }
}

local occupied: csml.State = new {
  entry {
    new csml.Eval { expression = "\(Vars.vCurrentOccupancy) = 'occupied'" }
  }
  on {
    ["sensorOccupancyReceived"] {

      yields {
        new csml.Invoke {
          type = ServiceTypes.stDetectOccupancy
          input { ["imageData"] = "$imageData" }
          emits { new csml.Internal { topic = "detectionDone" } }
        }
      }
    }
    ["detectionDone"] {
      yields {
        new csml.Eval { expression = "\(Vars.vOccupancyDetected) = $occupancyDetected" }
        new csml.Match {
          cases {
            new csml.Case {
              of = Guards.occupancyDetected
              yields { new csml.Emit { event = new csml.Internal { topic = "goOccupied" } } }
            }
          }
          default = new csml.Emit { event = new csml.Internal { topic = "goTransient" } }
        }
      }
    }
    ["goOccupied"] {
      to = "occupied"
      yields { Actions.aRaiseOccupancyDetected }
    }
    ["goTransient"] { to = "transient" }

    [Events.eActivateEnergySaving] {
      to = "transient"
      yields {
        new csml.Eval { expression = "\(Vars.vEnergySaving) = true" }
        Actions.aRaiseOccupancyTransient
      }
    }
  }
}

local transientState: csml.State = new {
  entry {
    new csml.Eval { expression = "\(Vars.vCurrentOccupancy) = 'transient'" }
    Actions.aRaiseOccupancyTransient
  }
  on {
    ["sensorOccupancyReceived"] {
      yields {
        new csml.Invoke {
          type = ServiceTypes.stDetectOccupancy
          input { ["imageData"] = "$imageData" }
          emits { new csml.Internal { topic = "detectionDone" } }
        }
      }
    }
    ["detectionDone"] {
      yields {
        new csml.Eval { expression = "\(Vars.vOccupancyDetected) = $occupancyDetected" }
        new csml.Match {
          cases {
            new csml.Case {
              of = Guards.occupancyDetected
              yields { new csml.Emit { event = new csml.Internal { topic = "goOccupied" } } }
            }
          }
          default = new csml.Emit { event = new csml.Internal { topic = "goVacant" } }
        }
      }
    }
    ["goOccupied"] {
      to = "occupied"
      yields { Actions.aRaiseOccupancyDetected }
    }
    ["goVacant"] { to = "vacant" yields { Actions.aRaiseOccupancyVacant } }
  }
}
