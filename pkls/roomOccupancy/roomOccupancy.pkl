import "../events.pkl" as Events
import "actions.pkl" as Actions
import "context.pkl" as Context
import "guards.pkl" as Guards
import "../serviceTypes.pkl" as ServiceTypes
import "../variables.pkl" as Vars
import "occupancyMonitor.pkl"
import "https://raw.githubusercontent.com/CollaborativeStateMachines/Cirrina/refs/heads/develop/src/main/resources/pkl/csm/csml.pkl"

// This module contains the definition for the room occupancy SM
sm = new csml.StateMachine {
  transient = Context.occupancyLocalContext
  stateMachines {
    ["occupancyMonitor"] = occupancyMonitor.sm
  }
  states {
    ["init"] = init
    ["vacant"] = vacant
    ["occupied"] = occupied
    ["transient"] = transientState
  }
}

// Initially the SM will always transition to vacant
local const init: csml.Initial = new {
  always {
    new csml.Transition { to = "vacant" }
  }
}

// State: Vacant
// Waits for external sensor data event
local const vacant: csml.State = new {
  entry {
    new csml.Eval { expression = "\(Vars.vCurrentOccupancy) = 'vacant'" }
  }
  on {
    ["sensorOccupancyReceived"] = new csml.Transition {
      do {
        new csml.Invoke {
          type = ServiceTypes.stDetectOccupancy
          input { ["imageData"] = "$imageData" }
          raises { new csml.Internal { topic = Events.eDetectionComplete } }
        }
      }
    }
    [Events.eDetectionComplete] = new csml.Transition {
      do {
        new csml.Eval { expression = "\(Vars.vOccupancyDetected) = $occupancyDetected" }
        new csml.Raise { event = new csml.Internal { topic = "processDetection" } }
      }
    }
    ["processDetection"] = new csml.Transition {
      to = "occupied"
      iif = Guards.occupancyDetected
      do {
        Actions.aRaiseOccupancyDetected
      }
      or = "vacant"
    }
  }
}

// State: Occupied
local const occupied: csml.State = new {
  entry {
    new csml.Eval { expression = "\(Vars.vCurrentOccupancy) = 'occupied'" }
  }
  on {
    ["sensorOccupancyReceived"] = new csml.Transition {
      do {
        new csml.Invoke {
          type = ServiceTypes.stDetectOccupancy
          input { ["imageData"] = "$imageData" }
          raises { new csml.Internal { topic = Events.eDetectionComplete } }
        }
      }
    }
    [Events.eDetectionComplete] = new csml.Transition {
      do {
        new csml.Eval { expression = "\(Vars.vOccupancyDetected) = $occupancyDetected" }
        new csml.Raise { event = new csml.Internal { topic = "processDetection" } }
      }
    }
    ["processDetection"] = new csml.Transition {
      to = "occupied"
      iif = Guards.occupancyDetected
      do {
        Actions.aRaiseOccupancyDetected
      }
      or = "transient"
    }
    [Events.eActivateEnergySaving] = new csml.Transition {
      to = "transient"
      do {
        new csml.Eval { expression = "\(Vars.vEnergySaving) = true" }
        Actions.aRaiseOccupancyTransient
      }
    }
  }
}

// State: Transient (Grace Period)
local const transientState: csml.State = new {
  entry {
    new csml.Eval { expression = "\(Vars.vCurrentOccupancy) = 'transient'" }
    Actions.aRaiseOccupancyTransient
  }
  on {
    ["sensorOccupancyReceived"] = new csml.Transition {
      do {
        new csml.Invoke {
          type = ServiceTypes.stDetectOccupancy
          input { ["imageData"] = "$imageData" }
          raises { new csml.Internal { topic = Events.eDetectionComplete } }
        }
      }
    }
    [Events.eDetectionComplete] = new csml.Transition {
      do {
        new csml.Eval { expression = "\(Vars.vOccupancyDetected) = $occupancyDetected" }
        new csml.Raise { event = new csml.Internal { topic = "processDetection" } }
      }
    }
    ["processDetection"] = new csml.Transition {
      to = "occupied"
      iif = Guards.occupancyDetected
      do  {
        Actions.aRaiseOccupancyDetected
      }
      or = "vacant"
    }
  }
}
