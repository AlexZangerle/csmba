import "https://raw.githubusercontent.com/CollaborativeStateMachines/Cirrina/refs/heads/develop/src/main/resources/pkl/csm/csml.pkl"
import "../events.pkl" as Events
import "../serviceTypes.pkl" as ServiceTypes
import "actions.pkl" as Actions

// Occupancy monitor — nested state machine within roomOccupancy.
// Watches for sensor events, starts a timeout, and escalates to
// maintenance if the detection service doesn't respond in time.
sm = new csml.StateMachine {
  states {
    ["idle"] = idle
    ["monitoring"] = monitoring
    ["maintenance"] = maintenance
  }
}

local idle: csml.Initial = new {
  on {
    ["sensorOccupancyReceived"] { to = "monitoring" }
  }
}

local monitoring: csml.State = new {
  after {
    ["serviceTimeout"] = new csml.Timeout {
      delay = "5000"
      triggers = Actions.aRaiseMaintenance
    }
  }
  on {
    [Events.eMaintenanceRequired] { to = "maintenance" }
    [Events.eDetectionComplete] { to = "idle" }
  }
}

local maintenance: csml.State = new {
  entry {
    new csml.Invoke { type = ServiceTypes.stMaintenance }
  }
  on {
    [Events.eMaintenanceDone] { to = "idle" }
  }
}
