amends "https://raw.githubusercontent.com/CollaborativeStateMachines/Cirrina/refs/heads/develop/src/main/resources/pkl/csm/csml.pkl"
import "https://raw.githubusercontent.com/CollaborativeStateMachines/Cirrina/refs/heads/develop/src/main/resources/pkl/csm/csml.pkl"
import "https://raw.githubusercontent.com/AlexZangerle/csmba/main/pkls/*.pkl" as Events
import "https://raw.githubusercontent.com/AlexZangerle/csmba/main/pkls/serviceTypes.pkl" as ServiceTypes
import "https://raw.githubusercontent.com/AlexZangerle/csmba/main/pkls/variables.pkl?v=1" as Vars
import "https://raw.githubusercontent.com/AlexZangerle/csmba/main/pkls/electricalSafety/electricalSafety.pkl" as electricalSafety
import "https://raw.githubusercontent.com/AlexZangerle/csmba/main/pkls/gasSafety/gasSafety.pkl" as gasSafety
import "https://raw.githubusercontent.com/AlexZangerle/csmba/main/pkls/tempSafety/tempSafety.pkl" as tempSafety
import "https://raw.githubusercontent.com/AlexZangerle/csmba/main/pkls/shading/shading.pkl?v=1" as shading
import "https://raw.githubusercontent.com/AlexZangerle/csmba/main/pkls/lighting/lighting.pkl" as lighting
import "https://raw.githubusercontent.com/AlexZangerle/csmba/main/pkls/roomOccupancy/roomOccupancy.pkl?v=1" as roomOccupancy
import "https://raw.githubusercontent.com/AlexZangerle/csmba/main/pkls/energyManagement/energyManagement.pkl?v=1" as energyManagement
import "https://raw.githubusercontent.com/AlexZangerle/csmba/main/pkls/fire/fire.pkl" as fire
import "https://raw.githubusercontent.com/AlexZangerle/csmba/main/pkls/hvac/hvac.pkl" as hvac
import "https://raw.githubusercontent.com/AlexZangerle/csmba/main/pkls/buildingSchedule/roomSchedule.pkl" as roomSchedule
import "https://raw.githubusercontent.com/AlexZangerle/csmba/main/pkls/security/securityManager.pkl" as securityManager
import "https://raw.githubusercontent.com/AlexZangerle/csmba/main/pkls/security/accessControl.pkl" as accessControl
import "https://raw.githubusercontent.com/AlexZangerle/csmba/main/pkls/buildingSchedule/buildingSchedule.pkl" as buildingSchedule

version = "4.0.0"
stateMachines {
  ["buildingSchedule"] = buildingSchedule.sm
}
persistent {
  [Vars.vEnergySaving] = "false"
  [Vars.vCurrentOccupancy] = "'vacant'"
  [Vars.vFireAlarm] = "false"
  [Vars.vSmokeAlert] = "false"
  [Vars.vTempThreshold] = "'60'"
  [Vars.vMaxEnergyPrice] = "'45.0'"
  [Vars.vDesiredTemp] = "'21.0'"
}
