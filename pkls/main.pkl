amends "https://raw.githubusercontent.com/CollaborativeStateMachines/Cirrina/refs/heads/develop/src/main/resources/pkl/csm/csml.pkl"
import "../variables.pkl" as Vars
import "buildingSchedule/buildingSchedule.pkl"
import "buildingSchedule/roomSchedule.pkl"
import "electricalSafety/electricalSafety.pkl"
import "energyManagement/energyManagement.pkl"
import "fire/fire.pkl"
import "fire/fireDoor.pkl"
import "gasSafety/gasSafety.pkl"
import "hvac/hvac.pkl"
import "lighting/lighting.pkl"
import "roomOccupancy/roomOccupancy.pkl"
import "security/accessControl.pkl"
import "security/securityManager.pkl"
import "shading/shading.pkl"
import "tempSafety/tempSafety.pkl"

collaborativeStateMachine {
  stateMachines {
    ["buildingSchedule"] = buildingSchedule.sm
    ["roomSchedule"] = roomSchedule.sm
    ["electricalSafety"] = electricalSafety.sm
    ["energyManagement"] = energyManagement.sm
    ["fire"] = fire.sm
    ["fireDoor"] = fireDoor.sm
    ["gasSafety"] = gasSafety.sm
    ["hvac"] = hvac.sm
    ["lighting"] = lighting.sm
    ["roomOccupancy"] = roomOccupancy.sm
    ["securityManager"] = securityManager.sm
    ["accessControl"] = accessControl.sm
    ["shading"] = shading.sm
    ["tempSafety"] = tempSafety.sm
  }
  persistent {
    [Vars.vEnergySaving] = "false"
    [Vars.vCurrentOccupancy] = "'vacant'"
    [Vars.vFireAlarm] = "false"
    [Vars.vGasActive] = "false"
    [Vars.vSmokeAlert] = "false"
    [Vars.vArcFault] = "false"
    [Vars.vTempThreshold] = "'60'"
    [Vars.vMaxEnergyPrice] = "'45.0'"
    [Vars.vDesiredTemp] = "'21.0'"
  }
}

instances {
  ["buildingSchedule"] { stateMachineName = "buildingSchedule" }
  ["roomSchedule"] { stateMachineName = "roomSchedule" data { [Vars.vRoomId] = "'Room 0'" } }
  ["electricalSafety"] { stateMachineName = "electricalSafety" }
  ["energyManagement"] { stateMachineName = "energyManagement" }
  ["fire"] { stateMachineName = "fire" }
  ["fireDoor"] { stateMachineName = "fireDoor" data { [Vars.vDoorId] = "'Door 0'" } }
  ["gasSafety"] { stateMachineName = "gasSafety" }
  ["hvac"] { stateMachineName = "hvac" data { [Vars.vRoomId] = "'Room 0'" } }
  ["lighting"] { stateMachineName = "lighting" data { [Vars.vRoomId] = "'Room 0'" } }
  ["roomOccupancy"] { stateMachineName = "roomOccupancy" data { [Vars.vRoomId] = "'Room 0'" } }
  ["securityManager"] { stateMachineName = "securityManager" }
  ["accessControl"] { stateMachineName = "accessControl" data { [Vars.vDoorId] = "'Door 0'" } }
  ["shading"] { stateMachineName = "shading" data { [Vars.vRoomId] = "'Room 0'" } }
  ["tempSafety"] { stateMachineName = "tempSafety" data { [Vars.vRoomId] = "'Room 0'" } }
}

bindings {
  new HttpServiceImplementationBinding {
    name = "checkArcFault"
    `local` = false
    scheme = "http"
    host = "localhost"
    port = 8005
    endPoint = "/checkArcFault"
    method = "POST"
  }
  new HttpServiceImplementationBinding {
    name = "tripCircuitBreaker"
    `local` = false
    scheme = "http"
    host = "localhost"
    port = 8005
    endPoint = "/tripCircuitBreaker"
