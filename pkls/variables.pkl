// This module contains all variable definitions for the CSM BMS

// Variable containing if occupancy has been detected (Boolean)
vOccupancyDetected = "occupancyDetected"

// Variable containing blinds lock status (Boolean)
vIsLocked = "isLocked"

// Variable containing the current outside temperature
vOutdoorTemp = "temperature"

// Variable containing the current building energy mode (Boolean)
vEnergySaving = "energySaving"

// Variable containing the current occupancy (String - occupied/vacant/transient)
vCurrentOccupancy = "currentOccupancy"

// Variable containing the light level set by user (int - 0-100)
vUserLightLevel = "lightLevel"

// Variable containing the blind level set by user (int - 0-100)
vUserBlindLevel = "blindLevel"

// Variable containing the result from fire detection (String - none/fire/smoke)
vFireDetectionResult = "fireDetectionResult"

// Variable containing the room Id in which the emergency is happening (String)
vEmergencyInRoom = "emergencyInRoom"

// Variable to show if fire alarm is currently active (Boolean)
vFireAlarm = "fireAlarm"

// Variable to show if smoke alert is currently active (Boolean)
vSmokeAlert = "smokeAlert"

// Variable containing the temperature threshold for critical equipment (int)
vTempThreshold = "tempThreshold"

// Variable containing the current roomID (int)
vRoomId = "roomId"


// Variable containing the temperature of critical equipment in vRoomId (int)
vRoomTemp = "roomTemp"

// Variable containing the location where arc fault occured (String)
vArcFaultLocation = "arcFaultLocation"

// Variable containing the location where gas leak occured (String)
vGasLeakLocation = "gasLeakLocation"

// Variable showing if gas leak is still active
vGasActive = "gasActive"

// Variable containing the current external energy prices
vEnergyPrice = "energyPrice"

// Variable containing the predefined maximum energy price
vMaxEnergyPrice = "maxEnergyPrice"

// Variable containing the current status of the grid
vGridStatus = "gridStatus"

vIndoorTemp = "indoorTemp"

vDesiredTemp = "desiredTemp"

vCurrentScheduleMode = "currentSchedule"

vZoneId = "zoneId"

vFailedAttemptsCount = "failedAttemptsCount"
vLastFailedAttemptTime = "lastFailedAttemptTime"
vAlertDetails = "alertDetails"
// Local context for AccessControlSM
vDoorId = "doorId"
vIsEvacuationRoute = "isEvacuationRoute"
vUserId = "userId"
vUserRole = "userRole"
vAuthenticationStatus = "authenticationStatus"
vAccessDecision = "accessDecision"
vCurrentSystemScheduleMode = "currentSystemSchedule"
