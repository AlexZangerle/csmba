import
  "https://raw.githubusercontent.com/CollaborativeStateMachines/Cirrina/refs/heads/develop/src/main/resources/pkl/csm/csml.pkl"

import "../events.pkl" as Events
import "../serviceTypes.pkl" as ServiceTypes
import "../variables.pkl" as Vars
import "context.pkl" as Context
import "guards.pkl" as Guards

// This module contains the definition for the lighting SM
sm = new csml.StateMachine {
  transient = Context.lightingContext
  states {
    ["init"] = init
    ["off"] = offState // Mapped to avoid keyword conflict
    ["on"] = turnOn
    ["dim"] = dim
    ["userLevel"] = userLevel
    ["fire"] = fire
    ["flashingAlarm_Off"] = flashingAlarm_Off
    ["flashingAlarm_On"] = flashingAlarm_On
  }
}

// Initially always transitions to off
local const init: csml.Initial = new {
  always {
    new csml.Transition { to = "off" }
  }
}

// Lights off - default state when inactive or vacant.
local const offState: csml.State = new {
  entry {
    new csml.Invoke {
      type = ServiceTypes.stTurnOff
    }
  }
  on {
    [Events.eOccupancyDetected] = new csml.Transition {
      to = "on"
      iif = Guards.energySavingInactive
      or = "dim" // If energy saving is active, go to dim instead
    }

    [Events.eActivateLightUserLevel] = new csml.Transition {
      to = "userLevel"
      // Capture the level from the event payload
      do { new csml.Eval { expression = "\(Vars.vUserLightLevel) = $lightLevel" } }
    }

    [Events.eAccessGranted] = new csml.Transition {
      to = "on"
      iif = Guards.isMyZone
    }

    // Security Alarm Override
    [Events.eFlashAllLights] = new csml.Transition {
      to = "flashingAlarm_Off"
    }

    // Fire Evacuation Override
    [Events.eFireAlarm] = new csml.Transition {
      to = "fire"
    }

    // Context Updates
    [Events.eActivateEnergySaving] = new csml.Transition {
      do { new csml.Eval { expression = "\(Vars.vEnergySaving) = true" } }
    }
    [Events.eDeactivateEnergySaving] = new csml.Transition {
      do { new csml.Eval { expression = "\(Vars.vEnergySaving) = false" } }
    }
  }
}

// Lights on - zone is active and occupied.
local const turnOn: csml.State = new {
  entry {
    new csml.Invoke {
      type = ServiceTypes.stTurnOn
    }
  }
  on {
    [Events.eOccupancyTransient] = new csml.Transition { to = "dim" }
    [Events.eOccupancyVacant] = new csml.Transition { to = "off" }

    [Events.eActivateLightUserLevel] = new csml.Transition {
      to = "userLevel"
      do { new csml.Eval { expression = "\(Vars.vUserLightLevel) = $lightLevel" } }
    }

    [Events.eZoneWarning] = new csml.Transition {
      to = "dim"
      iif = Guards.isMyZone
    }
    [Events.eZoneInactive] = new csml.Transition {
      to = "off"
      iif = Guards.isMyZone
    }

    [Events.eFlashAllLights] = new csml.Transition { to = "flashingAlarm_Off" }
    [Events.eFireAlarm] = new csml.Transition { to = "fire" }
  }
}

// Lights dim - grace period, warning, or energy saving.
local const dim: csml.State = new {
  entry {
    new csml.Invoke {
      type = ServiceTypes.stDim
    }
  }
  on {
    [Events.eOccupancyDetected] = new csml.Transition {
      to = "on"
      iif = Guards.energySavingInactive
      // Implicit else: stay in dim if energy saving is active
    }

    [Events.eOccupancyVacant] = new csml.Transition { to = "off" }

    [Events.eActivateLightUserLevel] = new csml.Transition {
      to = "userLevel"
      do { new csml.Eval { expression = "\(Vars.vUserLightLevel) = $lightLevel" } }
    }

    [Events.eZoneActive] = new csml.Transition {
      to = "on"
      iif = Guards.isMyZone
    }
    [Events.eZoneInactive] = new csml.Transition {
      to = "off"
      iif = Guards.isMyZone
    }

    [Events.eFlashAllLights] = new csml.Transition { to = "flashingAlarm_Off" }
    [Events.eFireAlarm] = new csml.Transition { to = "fire" }

    // Context Updates
    [Events.eActivateEnergySaving] = new csml.Transition {
      do { new csml.Eval { expression = "\(Vars.vEnergySaving) = true" } }
    }
    [Events.eDeactivateEnergySaving] = new csml.Transition {
      do { new csml.Eval { expression = "\(Vars.vEnergySaving) = false" } }
    }
  }
}

// Lights at manual level - user override.
local const userLevel: csml.State = new {
  static {
    [Vars.vUserLightLevel] = "'0'"
  }
  entry {
    new csml.Invoke {
      type = ServiceTypes.stTurnUserLevel
      input { ["lightLevel"] = Vars.vUserLightLevel }
    }
  }
  on {
    [Events.eDeactivateLightUserLevel] = new csml.Transition { to = "off" }

    [Events.eZoneWarning] = new csml.Transition {
      to = "dim"
      iif = Guards.isMyZone
    }
    [Events.eZoneInactive] = new csml.Transition {
      to = "off"
      iif = Guards.isMyZone
    }

    [Events.eFlashAllLights] = new csml.Transition { to = "flashingAlarm_Off" }
    [Events.eFireAlarm] = new csml.Transition { to = "fire" }
  }
}

// Fire Mode: Turns on emergency lights or directs path
local const fire: csml.State = new {
  entry {
    new csml.Invoke {
      type = ServiceTypes.stEvacuationLights
      input { ["roomId"] = "$emergencyInRoom" }
    }
  }
  on {
    [Events.eDisarmFireAlarm] = new csml.Transition {
      to = "off"
    }
  }
}

// Flashing lights states in case of intrusion
local const flashingAlarm_Off: csml.State = new {
  entry {
    new csml.Invoke { type = ServiceTypes.stTurnOff }
  }
  after {
    ["flashOffPeriodTimer"] = new csml.Timeout {
      delay = "1000"
      do = new csml.Raise { event = new csml.Internal { topic = "flashOn" } }
    }
  }
  on {
    ["flashOn"] = new csml.Transition {
      to = "flashingAlarm_On"
    }
    [Events.eClearSecurityAlert] = new csml.Transition {
      to = "off"
    }
  }
}

local const flashingAlarm_On: csml.State = new {
  entry {
    new csml.Invoke { type = ServiceTypes.stTurnOn }
  }
  after {
    ["flashOnPeriodTimer"] = new csml.Timeout {
      delay = "500"
      do = new csml.Raise { event = new csml.Internal { topic = "flashOff" } }
    }
  }
  on {
    ["flashOff"] = new csml.Transition {
      to = "flashingAlarm_Off"
    }
    [Events.eClearSecurityAlert] = new csml.Transition {
      to = "off"
    }
  }
}
