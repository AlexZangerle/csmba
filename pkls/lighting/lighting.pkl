import "https://raw.githubusercontent.com/CollaborativeStateMachines/Cirrina/refs/heads/develop/src/main/resources/pkl/csm/csml.pkl"
import "../events.pkl" as Events
import "../serviceTypes.pkl" as ServiceTypes
import "../variables.pkl" as Vars
import "guards.pkl" as Guards

// Lighting state machine definition.
sm = new csml.StateMachine {
  states {
    ["off"] = off
    ["on"] = on
    ["dim"] = dim
    ["userLevel"] = userLevel
    ["safetyOff"] = safetyOff
    ["flashingAlarm_Off"] = flashingAlarmOff
    ["flashingAlarm_On"] = flashingAlarmOn
  }
}

local off: csml.Initial = new {
  entry {
    new csml.Invoke { type = ServiceTypes.stTurnOff input { ["roomId"] = Vars.vRoomId } }
  }
  on {
    [Events.eOccupancyDetected] {
      to = "on"
      provided = Guards.energySavingInactive
      or = "dim"
    }
    [Events.eActivateLightUserLevel] { to = "userLevel" }
    [Events.eFlashAllLights] { to = "flashingAlarm_On" }
    [Events.eFireAlarm] {
      to = "safetyOff"
      yields { new csml.Invoke { type = ServiceTypes.stEvacuationLights input { ["emergencyRoomId"] = "$emergencyInRoom"; ["roomId"] = Vars.vRoomId } } }
    }
    [Events.eGasLeakDetected] {
      to = "safetyOff"
      yields { new csml.Invoke { type = ServiceTypes.stTurnOff input { ["roomId"] = Vars.vRoomId } } }
    }
    [Events.eArcFaultDetected] {
      to = "safetyOff"
      yields { new csml.Invoke { type = ServiceTypes.stTurnOff input { ["roomId"] = Vars.vRoomId } } }
    }
    [Events.eActivateEnergySaving] {
      yields { new csml.Eval { expression = "\(Vars.vEnergySaving) = true" } }
    }
    [Events.eDeactivateEnergySaving] {
      yields { new csml.Eval { expression = "\(Vars.vEnergySaving) = false" } }
    }
  }
}

local on: csml.State = new {
  entry {
    new csml.Invoke { type = ServiceTypes.stTurnOn input { ["roomId"] = Vars.vRoomId } }
  }
  on {
    [Events.eOccupancyTransient] { to = "dim" }
    [Events.eOccupancyVacant] { to = "off" }
    [Events.eActivateLightUserLevel] { to = "userLevel" }
    [Events.eFlashAllLights] { to = "flashingAlarm_On" }
    [Events.eFireAlarm] {
      to = "safetyOff"
      yields { new csml.Invoke { type = ServiceTypes.stEvacuationLights input { ["emergencyRoomId"] = "$emergencyInRoom"; ["roomId"] = Vars.vRoomId } } }
    }
    [Events.eGasLeakDetected] {
      to = "safetyOff"
      yields { new csml.Invoke { type = ServiceTypes.stTurnOff input { ["roomId"] = Vars.vRoomId } } }
    }
    [Events.eArcFaultDetected] {
      to = "safetyOff"
      yields { new csml.Invoke { type = ServiceTypes.stTurnOff input { ["roomId"] = Vars.vRoomId } } }
    }
  }
}

local dim: csml.State = new {
  entry {
    new csml.Invoke { type = ServiceTypes.stDim input { ["roomId"] = Vars.vRoomId } }
  }
  on {
    [Events.eOccupancyDetected] {
      to = "on"
      provided = Guards.energySavingInactive
    }
    [Events.eOccupancyVacant] { to = "off" }
    [Events.eActivateLightUserLevel] { to = "userLevel" }
    [Events.eFlashAllLights] { to = "flashingAlarm_On" }
    [Events.eFireAlarm] {
      to = "safetyOff"
      yields { new csml.Invoke { type = ServiceTypes.stEvacuationLights input { ["emergencyRoomId"] = "$emergencyInRoom"; ["roomId"] = Vars.vRoomId } } }
    }
    [Events.eGasLeakDetected] {
      to = "safetyOff"
      yields { new csml.Invoke { type = ServiceTypes.stTurnOff input { ["roomId"] = Vars.vRoomId } } }
    }
    [Events.eArcFaultDetected] {
      to = "safetyOff"
      yields { new csml.Invoke { type = ServiceTypes.stTurnOff input { ["roomId"] = Vars.vRoomId } } }
    }
    [Events.eActivateEnergySaving] {
      yields { new csml.Eval { expression = "\(Vars.vEnergySaving) = true" } }
    }
    [Events.eDeactivateEnergySaving] {
      yields { new csml.Eval { expression = "\(Vars.vEnergySaving) = false" } }
    }
  }
}

local userLevel: csml.State = new {
  static { [Vars.vUserLightLevel] = "0" }
  entry {
    new csml.Eval { expression = "\(Vars.vUserLightLevel) == (($lightLevel == -1) ? \(Vars.vUserLightLevel) : $lightLevel)" }
    new csml.Invoke {
      type = ServiceTypes.stTurnUserLevel
      input { ["lightLevel"] = Vars.vUserLightLevel; ["roomId"] = Vars.vRoomId }
    }
  }
  on {
    [Events.eDeactivateLightUserLevel] { to = "off" }
    [Events.eFlashAllLights] { to = "flashingAlarm_On" }
    [Events.eFireAlarm] {
      to = "safetyOff"
      yields { new csml.Invoke { type = ServiceTypes.stEvacuationLights input { ["emergencyRoomId"] = "$emergencyInRoom"; ["roomId"] = Vars.vRoomId } } }
    }
    [Events.eGasLeakDetected] {
      to = "safetyOff"
      yields { new csml.Invoke { type = ServiceTypes.stTurnOff input { ["roomId"] = Vars.vRoomId } } }
    }
    [Events.eArcFaultDetected] {
      to = "safetyOff"
      yields { new csml.Invoke { type = ServiceTypes.stTurnOff input { ["roomId"] = Vars.vRoomId } } }
    }
  }
}

local safetyOff: csml.State = new {
  on {
    [Events.eFireAlarm] {
      to = "safetyOff"
      yields {
        new csml.Invoke {
          type = ServiceTypes.stEvacuationLights
          input { ["emergencyRoomId"] = "$emergencyInRoom"; ["roomId"] = Vars.vRoomId }
        }
      }
    }
    [Events.eGasLeakDetected] {
      to = "safetyOff"
      yields { new csml.Invoke { type = ServiceTypes.stTurnOff input { ["roomId"] = Vars.vRoomId } } }
    }
    [Events.eArcFaultDetected] {
      to = "safetyOff"
      yields { new csml.Invoke { type = ServiceTypes.stTurnOff input { ["roomId"] = Vars.vRoomId } } }
    }
    [Events.eDisarmFireAlarm] {
      to = "off"
      provided = Guards.isSafeToExitEmergency
    }
    [Events.eGasPurged] {
      to = "off"
      provided = Guards.isSafeToExitEmergency
    }
    [Events.eResetElectricalFault] {
      to = "off"
      provided = Guards.isSafeToExitEmergency
    }
  }
}

local flashingAlarmOff: csml.State = new {
  entry {
    new csml.Invoke { type = ServiceTypes.stTurnOff input { ["roomId"] = Vars.vRoomId } }
  }
  after {
    ["flashTimer"] = new csml.Timeout {
      delay = "1000"
      triggers = new csml.Emit { event = new csml.Internal { topic = "flashOn" } }
    }
  }
  on {
    ["flashOn"] { to = "flashingAlarm_On" }
    [Events.eClearSecurityAlert] { to = "off" }
    [Events.eFireAlarm] {
      to = "safetyOff"
      yields { new csml.Invoke { type = ServiceTypes.stEvacuationLights input { ["emergencyRoomId"] = "$emergencyInRoom"; ["roomId"] = Vars.vRoomId } } }
    }
    [Events.eGasLeakDetected] {
      to = "safetyOff"
      yields { new csml.Invoke { type = ServiceTypes.stTurnOff input { ["roomId"] = Vars.vRoomId } } }
    }
    [Events.eArcFaultDetected] {
      to = "safetyOff"
      yields { new csml.Invoke { type = ServiceTypes.stTurnOff input { ["roomId"] = Vars.vRoomId } } }
    }
  }
}

local flashingAlarmOn: csml.State = new {
  entry {
    new csml.Invoke { type = ServiceTypes.stTurnOn input { ["roomId"] = Vars.vRoomId } }
  }
  after {
    ["flashTimer"] = new csml.Timeout {
      delay = "500"
      triggers = new csml.Emit { event = new csml.Internal { topic = "flashOff" } }
    }
  }
  on {
    ["flashOff"] { to = "flashingAlarm_Off" }
    [Events.eClearSecurityAlert] { to = "off" }
    [Events.eFireAlarm] {
      to = "safetyOff"
      yields { new csml.Invoke { type = ServiceTypes.stEvacuationLights input { ["emergencyRoomId"] = "$emergencyInRoom"; ["roomId"] = Vars.vRoomId } } }
    }
    [Events.eGasLeakDetected] {
      to = "safetyOff"
      yields { new csml.Invoke { type = ServiceTypes.stTurnOff input { ["roomId"] = Vars.vRoomId } } }
    }
    [Events.eArcFaultDetected] {
      to = "safetyOff"
      yields { new csml.Invoke { type = ServiceTypes.stTurnOff input { ["roomId"] = Vars.vRoomId } } }
    }
  }
}
