import "https://raw.githubusercontent.com/CollaborativeStateMachines/Cirrina/refs/heads/develop/src/main/resources/pkl/csm/csml.pkl"
import "../variables.pkl" as Vars

// Lighting state machine definition.
sm = new csml.StateMachine {
  states {
    ["off"] = off
    ["on"] = on
    ["dim"] = dim
    ["userLevel"] = userLevel
    ["safetyOff"] = safetyOff
    ["flashingAlarm_Off"] = flashingAlarmOff
    ["flashingAlarm_On"] = flashingAlarmOn
  }
}

local off: csml.Initial = new {
  entry {
    new csml.Invoke { type = "turnLightsOffService"; input { ["roomId"] = Vars.vRoomId } }
  }
  on {
    ["occupancyDetected"] {
      to = "on"
      provided = "!\(Vars.vEnergySaving)"
      or = "dim"
    }
    ["userLightLevel"] { to = "userLevel" }
    ["flashAllLights"] { to = "flashingAlarm_On" }
    ["fireAlarm"] {
      to = "safetyOff"
      yields {
        new csml.Invoke {
          type = "evacuationLightsService"
          input { ["emergencyRoomId"] = "$emergencyInRoom"; ["roomId"] = Vars.vRoomId }
        }
      }
    }
    ["gasLeakDetected"] {
      to = "safetyOff"
      yields {
        new csml.Invoke { type = "turnLightsOffService"; input { ["roomId"] = Vars.vRoomId } }
      }
    }
    ["arcFaultDetected"] {
      to = "safetyOff"
      yields {
        new csml.Invoke { type = "turnLightsOffService"; input { ["roomId"] = Vars.vRoomId } }
      }
    }
    ["energySaving"] {
      yields { new csml.Eval { expression = "\(Vars.vEnergySaving) = true" } }
    }
    ["deactivateEnergySaving"] {
      yields { new csml.Eval { expression = "\(Vars.vEnergySaving) = false" } }
    }
  }
}

local on: csml.State = new {
  entry {
    new csml.Invoke { type = "turnLightsOnService"; input { ["roomId"] = Vars.vRoomId } }
  }
  on {
    ["occupancyTransient"] { to = "dim" }
    ["occupancyVacant"] { to = "off" }
    ["userLightLevel"] { to = "userLevel" }
    ["flashAllLights"] { to = "flashingAlarm_On" }
    ["fireAlarm"] {
      to = "safetyOff"
      yields {
        new csml.Invoke {
          type = "evacuationLightsService"
          input { ["emergencyRoomId"] = "$emergencyInRoom"; ["roomId"] = Vars.vRoomId }
        }
      }
    }
    ["gasLeakDetected"] {
      to = "safetyOff"
      yields {
        new csml.Invoke { type = "turnLightsOffService"; input { ["roomId"] = Vars.vRoomId } }
      }
    }
    ["arcFaultDetected"] {
      to = "safetyOff"
      yields {
        new csml.Invoke { type = "turnLightsOffService"; input { ["roomId"] = Vars.vRoomId } }
      }
    }
  }
}

local dim: csml.State = new {
  entry {
    new csml.Invoke { type = "turnLightsDimService"; input { ["roomId"] = Vars.vRoomId } }
  }
  on {
    ["occupancyDetected"] {
      to = "on"
      provided = "!\(Vars.vEnergySaving)"
    }
    ["occupancyVacant"] { to = "off" }
    ["userLightLevel"] { to = "userLevel" }
    ["flashAllLights"] { to = "flashingAlarm_On" }
    ["fireAlarm"] {
      to = "safetyOff"
      yields {
        new csml.Invoke {
          type = "evacuationLightsService"
          input { ["emergencyRoomId"] = "$emergencyInRoom"; ["roomId"] = Vars.vRoomId }
        }
      }
    }
    ["gasLeakDetected"] {
      to = "safetyOff"
      yields {
        new csml.Invoke { type = "turnLightsOffService"; input { ["roomId"] = Vars.vRoomId } }
      }
    }
    ["arcFaultDetected"] {
      to = "safetyOff"
      yields {
        new csml.Invoke { type = "turnLightsOffService"; input { ["roomId"] = Vars.vRoomId } }
      }
    }
    ["energySaving"] {
      yields { new csml.Eval { expression = "\(Vars.vEnergySaving) = true" } }
    }
    ["deactivateEnergySaving"] {
      yields { new csml.Eval { expression = "\(Vars.vEnergySaving) = false" } }
    }
  }
}

local userLevel: csml.State = new {
  static { [Vars.vUserLightLevel] = "0" }
  entry {
    new csml.Eval {
      expression =
        "\(Vars.vUserLightLevel) == (($lightLevel == -1) ? \(Vars.vUserLightLevel) : $lightLevel)"
    }
    new csml.Invoke {
      type = "turnLightsUserLevelService"
      input { ["lightLevel"] = Vars.vUserLightLevel; ["roomId"] = Vars.vRoomId }
    }
  }
  on {
    ["deactivateUserLightLevel"] { to = "off" }
    ["flashAllLights"] { to = "flashingAlarm_On" }
    ["fireAlarm"] {
      to = "safetyOff"
      yields {
        new csml.Invoke {
          type = "evacuationLightsService"
          input { ["emergencyRoomId"] = "$emergencyInRoom"; ["roomId"] = Vars.vRoomId }
        }
      }
    }
    ["gasLeakDetected"] {
      to = "safetyOff"
      yields {
        new csml.Invoke { type = "turnLightsOffService"; input { ["roomId"] = Vars.vRoomId } }
      }
    }
    ["arcFaultDetected"] {
      to = "safetyOff"
      yields {
        new csml.Invoke { type = "turnLightsOffService"; input { ["roomId"] = Vars.vRoomId } }
      }
    }
  }
}

local safetyOff: csml.State = new {
  on {
    ["fireAlarm"] {
      to = "safetyOff"
      yields {
        new csml.Invoke {
          type = "evacuationLightsService"
          input { ["emergencyRoomId"] = "$emergencyInRoom"; ["roomId"] = Vars.vRoomId }
        }
      }
    }
    ["gasLeakDetected"] {
      to = "safetyOff"
      yields {
        new csml.Invoke { type = "turnLightsOffService"; input { ["roomId"] = Vars.vRoomId } }
      }
    }
    ["arcFaultDetected"] {
      to = "safetyOff"
      yields {
        new csml.Invoke { type = "turnLightsOffService"; input { ["roomId"] = Vars.vRoomId } }
      }
    }
    ["disarmFireAlarm"] {
      to = "off"
      provided = "!\(Vars.vGasActive) && !\(Vars.vFireAlarm) && !\(Vars.vArcFault)"
    }
    ["gasPurged"] {
      to = "off"
      provided = "!\(Vars.vGasActive) && !\(Vars.vFireAlarm) && !\(Vars.vArcFault)"
    }
    ["electricalReset"] {
      to = "off"
      provided = "!\(Vars.vGasActive) && !\(Vars.vFireAlarm) && !\(Vars.vArcFault)"
    }
  }
}

local flashingAlarmOff: csml.State = new {
  entry {
    new csml.Invoke { type = "turnLightsOffService"; input { ["roomId"] = Vars.vRoomId } }
  }
  after {
    ["flashTimer"] = new csml.Timeout {
      delay = "1000"
      triggers = new csml.Emit { event = new csml.Internal { topic = "flashOn" } }
    }
  }
  on {
    ["flashOn"] { to = "flashingAlarm_On" }
    ["clearSecurityAlert"] { to = "off" }
    ["fireAlarm"] {
      to = "safetyOff"
      yields {
        new csml.Invoke {
          type = "evacuationLightsService"
          input { ["emergencyRoomId"] = "$emergencyInRoom"; ["roomId"] = Vars.vRoomId }
        }
      }
    }
    ["gasLeakDetected"] {
      to = "safetyOff"
      yields {
        new csml.Invoke { type = "turnLightsOffService"; input { ["roomId"] = Vars.vRoomId } }
      }
    }
    ["arcFaultDetected"] {
      to = "safetyOff"
      yields {
        new csml.Invoke { type = "turnLightsOffService"; input { ["roomId"] = Vars.vRoomId } }
      }
    }
  }
}

local flashingAlarmOn: csml.State = new {
  entry {
    new csml.Invoke { type = "turnLightsOnService"; input { ["roomId"] = Vars.vRoomId } }
  }
  after {
    ["flashTimer"] = new csml.Timeout {
      delay = "500"
      triggers = new csml.Emit { event = new csml.Internal { topic = "flashOff" } }
    }
  }
  on {
    ["flashOff"] { to = "flashingAlarm_Off" }
    ["clearSecurityAlert"] { to = "off" }
    ["fireAlarm"] {
      to = "safetyOff"
      yields {
        new csml.Invoke {
          type = "evacuationLightsService"
          input { ["emergencyRoomId"] = "$emergencyInRoom"; ["roomId"] = Vars.vRoomId }
        }
      }
    }
    ["gasLeakDetected"] {
      to = "safetyOff"
      yields {
        new csml.Invoke { type = "turnLightsOffService"; input { ["roomId"] = Vars.vRoomId } }
      }
    }
    ["arcFaultDetected"] {
      to = "safetyOff"
      yields {
        new csml.Invoke { type = "turnLightsOffService"; input { ["roomId"] = Vars.vRoomId } }
      }
    }
  }
}
