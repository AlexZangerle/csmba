import "https://raw.githubusercontent.com/CollaborativeStateMachines/Cirrina/refs/heads/develop/src/main/resources/pkl/csm/csml.pkl"
import "../events.pkl" as Events
import "../serviceTypes.pkl" as ServiceTypes
import "../variables.pkl" as Vars
import "context.pkl" as Context
import "guards.pkl" as Guards

// Lighting state machine definition.
sm = new csml.StateMachine {
  transient = Context.lightingContext
  states {
    ["off"] = off
    ["on"] = on
    ["dim"] = dim
    ["userLevel"] = userLevel
    ["fire"] = fire
    ["safetyOff"] = safetyOff
    ["flashingAlarm_Off"] = flashingAlarmOff
    ["flashingAlarm_On"] = flashingAlarmOn
  }
}

local off: csml.Initial = new {
  entry {
    new csml.Invoke { type = ServiceTypes.stTurnOff }
  }
  on {
    [Events.eOccupancyDetected] {
      to = "on"
      provided = Guards.energySavingInactive
      or = "dim"
    }
    [Events.eActivateLightUserLevel] {
      to = "userLevel"
      yields { new csml.Assign { expression = "\(Vars.vUserLightLevel) = $lightLevel" } }
    }
    [Events.eFlashAllLights] { to = "flashingAlarm_On" }
    [Events.eFireAlarm] { to = "fire" }
    [Events.eGasLeakDetected] { to = "safetyOff" }
    [Events.eActivateEnergySaving] {
      yields { new csml.Assign { expression = "\(Vars.vEnergySaving) = true" } }
    }
    [Events.eDeactivateEnergySaving] {
      yields { new csml.Assign { expression = "\(Vars.vEnergySaving) = false" } }
    }
  }
}

local on: csml.State = new {
  entry {
    new csml.Invoke { type = ServiceTypes.stTurnOn }
  }
  on {
    [Events.eOccupancyTransient] { to = "dim" }
    [Events.eOccupancyVacant] { to = "off" }
    [Events.eActivateLightUserLevel] {
      to = "userLevel"
      yields { new csml.Assign { expression = "\(Vars.vUserLightLevel) = $lightLevel" } }
    }
    [Events.eFlashAllLights] { to = "flashingAlarm_On" }
    [Events.eFireAlarm] { to = "fire" }
    [Events.eGasLeakDetected] { to = "safetyOff" }
  }
}

local dim: csml.State = new {
  entry {
    new csml.Invoke { type = ServiceTypes.stDim }
  }
  on {
    [Events.eOccupancyDetected] {
      to = "on"
      provided = Guards.energySavingInactive
    }
    [Events.eOccupancyVacant] { to = "off" }
    [Events.eActivateLightUserLevel] {
      to = "userLevel"
      yields { new csml.Assign { expression = "\(Vars.vUserLightLevel) = $lightLevel" } }
    }
    [Events.eFlashAllLights] { to = "flashingAlarm_On" }
    [Events.eFireAlarm] { to = "fire" }
    [Events.eGasLeakDetected] { to = "safetyOff" }
    [Events.eActivateEnergySaving] {
      yields { new csml.Assign { expression = "\(Vars.vEnergySaving) = true" } }
    }
    [Events.eDeactivateEnergySaving] {
      yields { new csml.Assign { expression = "\(Vars.vEnergySaving) = false" } }
    }
  }
}

local userLevel: csml.State = new {
  static { [Vars.vUserLightLevel] = "'0'" }
  entry {
    new csml.Invoke {
      type = ServiceTypes.stTurnUserLevel
      input { ["lightLevel"] = Vars.vUserLightLevel }
      emits { new csml.Internal { topic = "userLevelSet" } }
    }
  }
  on {
    ["userLevelSet"] { to = "userLevel" }
    [Events.eDeactivateLightUserLevel] { to = "off" }
    [Events.eFlashAllLights] { to = "flashingAlarm_On" }
    [Events.eFireAlarm] { to = "fire" }
    [Events.eGasLeakDetected] { to = "safetyOff" }
  }
}

local fire: csml.State = new {
  entry {
    new csml.Invoke {
      type = ServiceTypes.stEvacuationLights
      input { ["roomId"] = "$emergencyInRoom" }
    }
  }
  on {
    [Events.eDisarmFireAlarm] { to = "off" }
    [Events.eGasLeakDetected] { to = "safetyOff" }
  }
}

local safetyOff: csml.State = new {
  entry {
    new csml.Invoke { type = ServiceTypes.stTurnOff }
  }
  on {
    [Events.eGasPurged] {
      to = "fire"
      provided = Guards.isFireActive
      or = "off"
    }
  }
}

local flashingAlarmOff: csml.State = new {
  entry {
    new csml.Invoke { type = ServiceTypes.stTurnOff }
  }
  after {
    ["flashTimer"] = new csml.Timeout {
      delay = "1000"
      triggers = new csml.Emit { event = new csml.Internal { topic = "flashOn" } }
    }
  }
  on {
    ["flashOn"] { to = "flashingAlarm_On" }
    [Events.eClearSecurityAlert] { to = "off" }
    [Events.eFireAlarm] { to = "fire" }
    [Events.eGasLeakDetected] { to = "safetyOff" }
  }
}

local flashingAlarmOn: csml.State = new {
  entry {
    new csml.Invoke { type = ServiceTypes.stTurnOn }
  }
  after {
    ["flashTimer"] = new csml.Timeout {
      delay = "500"
      triggers = new csml.Emit { event = new csml.Internal { topic = "flashOff" } }
    }
  }
  on {
    ["flashOff"] { to = "flashingAlarm_Off" }
    [Events.eClearSecurityAlert] { to = "off" }
    [Events.eFireAlarm] { to = "fire" }
    [Events.eGasLeakDetected] { to = "safetyOff" }
  }
}
