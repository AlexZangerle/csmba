import "../variables.pkl" as Vars

// This module contains all guards for lightingSM

// Guards to verify if energySavingMode is either on or off
energySavingActive = "\(Vars.vEnergySaving)"


energySavingInactive = "!\(Vars.vEnergySaving)"

// Guard to verify if current occupancy is vacant
occupancyVacantGuard = "\(Vars.vCurrentOccupancy) == 'vacant'"


// Guard to verify if current occupancy is occupied
occupancyOccupiedGuard = "\(Vars.vCurrentOccupancy) == 'occupied'"


// Guard to verify if current occupancy is transient
occupancyTransientGuard = "\(Vars.vCurrentOccupancy) == 'transient'"

isFireActive = "\(Vars.vFireAlarm)"

isSafeToExitEmergency = "!\(Vars.vGasActive) && !\(Vars.vFireAlarm) && !\(Vars.vArcFault)"