import "https://raw.githubusercontent.com/CollaborativeStateMachines/Cirrina/refs/heads/develop/src/main/resources/pkl/csm/csml.pkl"
import "../events.pkl" as Events
import "../serviceTypes.pkl" as ServiceTypes
import "../variables.pkl" as Vars
import "actions.pkl" as Actions
import "context.pkl" as Context
import "guards.pkl" as Guards

// Access control state machine definition.
//
// Per-door controller handling authentication, rule checks, and physical security.
sm = new csml.StateMachine {
  transient = Context.accessControlContext
  states {
    ["init"] = init
    ["locked"] = locked
    ["authenticating"] = authenticating
    ["checkingRules"] = checkingRules
    ["unlocked"] = unlocked
    ["accessDenied"] = accessDenied
    ["emergencyUnlock"] = emergencyUnlock
    ["forcedOpenAlarm"] = forcedOpenAlarm
  }
}

local init: csml.Initial = new {
  entry {
    new csml.Invoke {
      type = ServiceTypes.stGetDoorRouteType
      input { ["doorId"] = Vars.vDoorId }
      emits { new csml.Internal { topic = "doorTypeDetermined" } }
    }
  }
  on {
    ["doorTypeDetermined"] {
      to = "locked"
      yields {
        new csml.Assign { expression = "\(Vars.vIsEvacuationRoute) = $isEvacuationRoute" }
      }
    }
  }
}

local locked: csml.State = new {
  on {
    [Events.eAuthenticationRequest] { to = "authenticating"; }
    [Events.eFireAlarm] { to = "emergencyUnlock" }
    [Events.eGasLeakDetected] { to = "emergencyUnlock"; provided = Guards.checkIsEvacuationRoute }
    [Events.eUnlockAllEvacuationRoutes] { to = "emergencyUnlock"; provided = Guards.checkIsEvacuationRoute }
    [Events.eLockdownZone] {}
    [Events.eDoorForcedOpen] { to = "forcedOpenAlarm" }
    [Events.ePhysicalTamper] { to = "forcedOpenAlarm" }
    [Events.eForceUnlockRequest] { to = "unlocked" }
  }
}

local authenticating: csml.State = new {
  entry {
    new csml.Invoke {
      type = ServiceTypes.stAuthenticateUser
      input { ["cardId"] = "$cardId" }
      emits { new csml.Internal { topic = "authDone" } }
    }
  }
  on {
    ["authDone"] {
      yields {
        new csml.Assign { expression = "\(Vars.vUserId) = $userId" }
        new csml.Assign { expression = "\(Vars.vUserRole) = $userRole" }
        new csml.Assign { expression = "\(Vars.vAuthenticationStatus) = $authenticationStatus" }
        new csml.Match {
          cases {
            new csml.Case {
              of = Guards.authSuccessful
              yields { new csml.Emit { event = new csml.Internal { topic = "goCheckRules" } } }
            }
          }
          default = new csml.Emit { event = new csml.Internal { topic = "goDeniedAuth" } }
        }
      }
    }
    ["goCheckRules"] { to = "checkingRules" }
    ["goDeniedAuth"] {
      to = "accessDenied"
      yields { Actions.aRaiseAccessDeniedAuth }
    }

    [Events.eFireAlarm] { to = "emergencyUnlock" }
  }
}

local checkingRules: csml.State = new {
  entry {
    new csml.Invoke {
      type = ServiceTypes.stCheckAccessRule
      input {
        ["userRole"] = Vars.vUserRole
        ["zoneId"] = Vars.vZoneId
        ["currentScheduleMode"] = Vars.vCurrentScheduleMode
      }
      emits { new csml.Internal { topic = "rulesDone" } }
    }
  }
  on {
    ["rulesDone"] {
      yields {
        new csml.Assign { expression = "\(Vars.vAccessDecision) = $accessDecision" }
        new csml.Match {
          cases {
            new csml.Case {
              of = Guards.allowAccess
              yields { new csml.Emit { event = new csml.Internal { topic = "goUnlocked" } } }
            }
          }
          default = new csml.Emit { event = new csml.Internal { topic = "goDeniedRule" } }
        }
      }
    }
    ["goUnlocked"] {
      to = "unlocked"
      yields { Actions.aRaiseAccessGranted }
    }
    ["goDeniedRule"] {
      to = "accessDenied"
      yields { Actions.aRaiseAccessDeniedRule }
    }

    [Events.eFireAlarm] { to = "emergencyUnlock" }
  }
}

local unlocked: csml.State = new {
  entry {
    new csml.Invoke {
      type = ServiceTypes.stControlDoorLock
      input { ["doorId"] = Vars.vDoorId; ["command"] = "'unlock'" }
    }
  }
  after {
    ["autoRelock"] = new csml.Timeout {
      delay = "10000"
      triggers = Actions.aRaiseAutoRelock
    }
  }
  on {
    ["autoRelock"] { to = "locked" }
    [Events.eLockdownZone] { to = "locked"; }
    [Events.eFireAlarm] { to = "emergencyUnlock" }
    [Events.eDoorForcedOpen] { to = "forcedOpenAlarm" }
    [Events.ePhysicalTamper] { to = "forcedOpenAlarm" }
  }
}

local accessDenied: csml.State = new {
  after {
    ["deniedDelay"] = new csml.Timeout {
      delay = "3000"
      triggers = Actions.aRaiseReturnToLock
    }
  }
  on {
    ["returnToLock"] { to = "locked" }
    [Events.eFireAlarm] { to = "emergencyUnlock" }
  }
}

local emergencyUnlock: csml.State = new {
  entry {
    new csml.Invoke {
      type = ServiceTypes.stControlDoorLock
      input { ["doorId"] = Vars.vDoorId; ["command"] = "'unlock'" }
    }
  }
  on {
    [Events.eDisarmFireAlarm] {
      to = "locked"
      provided = Guards.isSafeToExitEmergency
    }
    [Events.eGasPurged] {
      to = "locked"
      provided = Guards.isSafeToExitEmergency
    }
  }
}

local forcedOpenAlarm: csml.State = new {
  entry {
    Actions.aRaiseForcedEntry
    new csml.Invoke {
      type = ServiceTypes.stControlDoorLock
      input { ["doorId"] = Vars.vDoorId; ["command"] = "'lock'" }
    }
  }
  on {
    [Events.eClearSecurityAlert] { to = "locked" }
    [Events.eFireAlarm] { to = "emergencyUnlock" }
  }
}
