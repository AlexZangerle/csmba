import
  "https://raw.githubusercontent.com/CollaborativeStateMachines/Cirrina/refs/heads/develop/src/main/resources/pkl/csm/csml.pkl"

import "../events.pkl" as Events
import "../serviceTypes.pkl" as ServiceTypes
import "../variables.pkl" as Vars
import "context.pkl" as Context
import "actions.pkl" as Actions
import "guards.pkl" as Guards

/// This module defines the accessControlSM for a single access-controlled door.
sm = new csml.StateMachine {
  transient = Context.accessControlContext
  states {
    ["init"] = init
    ["initializing"] = initializing
    ["locked"] = locked
    ["authenticating"] = authenticating
    ["checkAuthResult"] = checkAuthResult
    ["checkingRules"] = checkingRules
    ["checkRuleResult"] = checkRuleResult
    ["unlocked"] = unlocked
    ["accessDenied"] = accessDenied
    ["emergencyUnlock"] = emergencyUnlock
    ["forcedOpenAlarm"] = forcedOpenAlarm
  }
}

local const init: csml.Initial = new {
  always {
    new csml.Transition { to = "initializing" }
  }
}

// Setup state: Determines if this door is an evacuation route
local const initializing: csml.State = new {
  entry {
    new csml.Invoke {
      type = ServiceTypes.stGetDoorRouteType
      input { ["doorId"] = Vars.vDoorId }
      raises { new csml.Internal { topic = "doorTypeDetermined" } }
    }
  }
  on {
    ["doorTypeDetermined"] = new csml.Transition {
      do {
        new csml.Eval { expression = "\(Vars.vIsEvacuationRoute) = $isEvacuationRoute" }
      }
      to = "locked"
    }
  }
}

/// Default locked state, listens for access attempts and overrides.
local const locked: csml.State = new {
  on {
    [Events.eAuthenticationRequest] = new csml.Transition {
      to = "authenticating"
      iif = Guards.isCurrentDoor
    }
    [Events.eFireAlarm] = new csml.Transition { to = "emergencyUnlock" }
    [Events.eGasLeakDetected] = new csml.Transition {
      to = "emergencyUnlock"
      iif = Guards.checkIsEvacuationRoute
    }
    [Events.eUnlockAllEvacuationRoutes] = new csml.Transition {
      to = "emergencyUnlock"
      iif = Guards.checkIsEvacuationRoute
    }

    [Events.eLockdownZone] = new csml.Transition {
      iif = Guards.isCurrentZone
    }

    [Events.eDoorForcedOpen] = new csml.Transition { to = "forcedOpenAlarm" }
    [Events.ePhysicalTamper] = new csml.Transition { to = "forcedOpenAlarm" }
    [Events.eForceUnlockRequest] = new csml.Transition { to = "unlocked" }
  }
}

/// Calls the authentication service.
local const authenticating: csml.State = new {
  entry {
    new csml.Invoke {
      type = ServiceTypes.stAuthenticateUser
      input { ["cardId"] = "$cardId" }
      raises { new csml.Internal { topic = "authComplete" } }
    }
  }
  on {
    ["authComplete"] = new csml.Transition {
      do {
        new csml.Eval { expression = "\(Vars.vUserId) = $userId" }
        new csml.Eval { expression = "\(Vars.vUserRole) = $userRole" }
        new csml.Eval { expression = "\(Vars.vAuthenticationStatus) = $authenticationStatus" }
        new csml.Raise { event = new csml.Internal { topic = "checkAuth" } }
      }
    }
    ["checkAuth"] = new csml.Transition {
      to = "checkAuthResult"
    }
    [Events.eFireAlarm] = new csml.Transition { to = "emergencyUnlock" }
  }
}

// Logic State for Auth
local const checkAuthResult: csml.State = new {
  always {
    new csml.Transition {
      to = "checkingRules"
      iif = Guards.authSuccessful
      or = "accessDenied"
      do { Actions.aRaiseAccessDeniedAuth }
    }
  }
}

/// Calls the rule checking service based on authenticated role and current schedule.
local const checkingRules: csml.State = new {
  entry {
    new csml.Invoke {
      type = ServiceTypes.stCheckAccessRule
      input {
        ["userRole"] = Vars.vUserRole
        ["zoneId"] = Vars.vZoneId
        ["currentScheduleMode"] = Vars.vCurrentScheduleMode
      }
      raises { new csml.Internal { topic = "rulesChecked" } }
    }
  }
  on {
    ["rulesChecked"] = new csml.Transition {
      do {
        new csml.Eval { expression = "\(Vars.vAccessDecision) = $accessDecision" }
        new csml.Raise { event = new csml.Internal { topic = "checkRules" } }
      }
    }
    ["checkRules"] = new csml.Transition {
      to = "checkRuleResult"
    }
    [Events.eFireAlarm] = new csml.Transition { to = "emergencyUnlock" }
  }
}

// Logic State for Rules
local const checkRuleResult: csml.State = new {
  always {
    new csml.Transition {
      to = "unlocked"
      iif = Guards.allowAccess
      do {
        Actions.aRaiseAccessGranted
        Actions.aRaiseAccessDeniedRule
      }
      or = "accessDenied"
    }
  }
}

/// Door is temporarily unlocked.
local const unlocked: csml.State = new {
  entry {
    new csml.Invoke {
      type = ServiceTypes.stControlDoorLock
      input {
        ["doorId"] = Vars.vDoorId
        ["command"] = "'unlock'"
      }
    }
  }
  after {
    ["autoRelockTimer"] = new csml.Timeout {
      delay = "10000"
      do = Actions.aRaiseAutoRelock
    }
  }
  on {
    ["autoRelock"] = new csml.Transition { to = "locked" }

    [Events.eLockdownZone] = new csml.Transition {
      to = "locked"
      iif = Guards.isCurrentZone
    }

    [Events.eFireAlarm] = new csml.Transition { to = "emergencyUnlock" }
    [Events.eDoorForcedOpen] = new csml.Transition { to = "forcedOpenAlarm" }
    [Events.ePhysicalTamper] = new csml.Transition { to = "forcedOpenAlarm" }
  }
}

/// Access was denied, briefly show status, then re-lock.
local const accessDenied: csml.State = new {
  after {
    ["deniedDelay"] = new csml.Timeout {
      delay = "3000"
      do = Actions.aRaiseReturnToLock
    }
  }
  on {
    ["returnToLock"] = new csml.Transition { to = "locked" }
    [Events.eFireAlarm] = new csml.Transition { to = "emergencyUnlock" }
  }
}

/// Highest priority state, forces door unlocked.
local const emergencyUnlock: csml.State = new {
  entry {
    new csml.Invoke {
      type = ServiceTypes.stControlDoorLock
      input {
        ["doorId"] = Vars.vDoorId
        ["command"] = "'unlock'"
      }
    }
  }
  on {
    [Events.eDisarmFireAlarm] = new csml.Transition { to = "locked" }
    [Events.eGasPurged] = new csml.Transition { to = "locked" }
  }
}

/// Alarm state if physical tampering or forced entry is detected.
local const forcedOpenAlarm: csml.State = new {
  entry {
    Actions.aRaiseForcedEntry
    new csml.Invoke {
      type = ServiceTypes.stControlDoorLock
      input {
        ["doorId"] = Vars.vDoorId
        ["command"] = "'lock'"
      }
    }
  }
  on {
    [Events.eClearSecurityAlert] = new csml.Transition { to = "locked" }
    [Events.eFireAlarm] = new csml.Transition { to = "emergencyUnlock" }
  }
}
