import "https://raw.githubusercontent.com/CollaborativeStateMachines/Cirrina/refs/heads/develop/src/main/resources/pkl/csm/csml.pkl"
import "../events.pkl" as Events
import "../serviceTypes.pkl" as ServiceTypes
import "../variables.pkl" as Vars
import "actions.pkl" as Actions
import "context.pkl" as Context
import "guards.pkl" as Guards

// Security manager state machine definition.
//
// Failed access attempts increment a counter; soft limit triggers elevated,
// hard limit triggers intrusion. Forced entry / tamper skip straight to intrusion.
sm = new csml.StateMachine {
  transient = Context.securityManagerContext
  states {
    ["secure"] = secure
    ["elevatedRisk"] = elevatedRisk
    ["intrusionAlert"] = intrusionAlert
    ["emergencyResponse"] = emergencyResponse
  }
}

local secure: csml.Initial = new {
  entry {
    new csml.Eval { expression = "\(Vars.vFailedAttemptsCount) = 0" }
    new csml.Eval { expression = "\(Vars.vAlertDetails) = ''" }
  }
  on {
    [Events.eForcedEntry] {
      to = "intrusionAlert"
      yields {
        new csml.Eval { expression = "\(Vars.vAlertDetails) = 'Forced entry detected at door ' + $doorId + ' in zone ' + $zone" }
      }
    }
    [Events.eTamperDetected] {
      to = "intrusionAlert"
      yields {
        new csml.Eval { expression = "\(Vars.vAlertDetails) = 'Tamper detected on device ' + $deviceId + ' at ' + $location" }
      }
    }
    [Events.eManualSecurityAlert] { to = "intrusionAlert" }
    [Events.eAccessDenied] {
      yields {
        new csml.Eval { expression = "\(Vars.vFailedAttemptsCount) = \(Vars.vFailedAttemptsCount) + 1" }
        new csml.Eval { expression = "\(Vars.vAlertDetails) = 'Repeated access denied at door ' + $doorId + '. User: ' + $user" }
        new csml.Match {
          cases {
            new csml.Case {
              of = Guards.failedAttemptSoftlimitReached
              yields { new csml.Emit { event = new csml.Internal { topic = "goElevated" } } }
            }
          }
        }
      }
    }
    ["goElevated"] { to = "elevatedRisk" }

    [Events.eFireAlarm] { to = "emergencyResponse" }
    [Events.eGasLeakDetected] { to = "emergencyResponse" }
  }
}

local elevatedRisk: csml.State = new {
  entry {
    new csml.Invoke {
      type = ServiceTypes.stNotifySecurityPersonnel
      input { ["message"] = Vars.vAlertDetails }
    }
    Actions.aRaiseSecurityBreach
  }
  after {
    ["riskDecay"] = new csml.Timeout {
      delay = "1800000"
      triggers = new csml.Emit { event = new csml.Internal { topic = "decayRisk" } }
    }
  }
  on {
    ["decayRisk"] { to = "secure" }

    [Events.eAccessDenied] {
      yields {
        new csml.Eval { expression = "\(Vars.vFailedAttemptsCount) = \(Vars.vFailedAttemptsCount) + 1" }
        new csml.Eval { expression = "\(Vars.vAlertDetails) = 'Escalation: Further access denied at door ' + $doorId + '. User: ' + $user" }
        new csml.Match {
          cases {
            new csml.Case {
              of = Guards.failedAttemptHardlimitReached
              yields { new csml.Emit { event = new csml.Internal { topic = "goIntrusion" } } }
            }
          }
        }
      }
    }
    ["goIntrusion"] { to = "intrusionAlert" }

    [Events.eForcedEntry] { to = "intrusionAlert" }
    [Events.eTamperDetected] { to = "intrusionAlert" }
    [Events.eManualSecurityAlert] { to = "intrusionAlert" }
    [Events.eClearSecurityAlert] { to = "secure" }

    [Events.eFireAlarm] { to = "emergencyResponse" }
    [Events.eGasLeakDetected] { to = "emergencyResponse" }
  }
}

local intrusionAlert: csml.State = new {
  entry {
    Actions.aRaiseServereSecurityBreach
    Actions.aRaiseFlashLights
    Actions.aRaiseBuildingAlarm
    new csml.Invoke {
      type = ServiceTypes.stNotifySecurityPersonnel
      input { ["message"] = "'INTRUSION ALERT:' + \(Vars.vAlertDetails)" }
    }
  }
  on {
    [Events.eClearSecurityAlert] { to = "secure" }
    [Events.eFireAlarm] { to = "emergencyResponse" }
    [Events.eGasLeakDetected] { to = "emergencyResponse" }
  }
}

local emergencyResponse: csml.State = new {
  entry {
    Actions.aRaiseUnlockEvacuationRoutes
  }
  on {
    [Events.eDisarmFireAlarm] {
      to = "secure"
      provided = Guards.isSafeToExitEmergency
    }
    [Events.eGasPurged] {
      to = "secure"
      provided = Guards.isSafeToExitEmergency
    }
  }
}
