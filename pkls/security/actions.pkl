import "https://raw.githubusercontent.com/CollaborativeStateMachines/Cirrina/refs/heads/develop/src/main/resources/pkl/csm/csml.pkl"
import "../events.pkl" as Events
import "../variables.pkl" as Vars
// This module contains actions for the accessControlSM and securityManagerSM

// Raise to signify elevated security breach
aRaiseSecurityBreach = new csml.Emit {
  event = new csml.Global {
    topic = Events.eSecurityBreachNotification
    data {
      ["level"] = "'Elevated'"
      ["details"] = Vars.vAlertDetails
    }
  }
}

// Raise to signify high security breach
aRaiseServereSecurityBreach = new csml.Emit {
  event = new csml.Global {
    topic = Events.eSecurityBreachNotification
    data {
      ["level"] = "'High'"
      ["details"] = Vars.vAlertDetails
    }
  }
}

// Raise to start flashing lights
aRaiseFlashLights = new csml.Emit { event = new csml.Global { topic = Events.eFlashAllLights } }

// Raise to start the building alarm
aRaiseBuildingAlarm = new csml.Emit {
  event = new csml.Global { topic = Events.eActivateBuildingAlarm }
}

// Raise to unlock evacuation routes
aRaiseUnlockEvacuationRoutes = new csml.Emit {
  event = new csml.Global { topic = Events.eUnlockAllEvacuationRoutes }
}

// Raise if access was denied based on authentication
aRaiseAccessDeniedAuth = new csml.Emit {
  event = new csml.Global {
    topic = Events.eAccessDenied
    data {
      ["doorId"] = Vars.vDoorId
      ["zoneId"] = Vars.vZoneId
      ["user"] = "'unknown'"
      ["reason"] = "'Authentication Failed'"
    }
  }
}

// Raise if access was denied based on rule
aRaiseAccessDeniedRule = new csml.Emit {
  event = new csml.Global {
    topic = Events.eAccessDenied
    data {
      ["doorId"] = Vars.vDoorId
      ["zoneId"] = Vars.vZoneId
      ["user"] = Vars.vUserId
      ["reason"] = "'Access Rule Denied'"
    }
  }
}

// Raise if access was granted
aRaiseAccessGranted = new csml.Emit {
  event = new csml.Global {
    topic = Events.eAccessGranted
    data {
      ["doorId"] = Vars.vDoorId
      ["zoneId"] = Vars.vZoneId
      ["user"] = Vars.vUserId
      ["role"] = Vars.vUserRole
    }
  }
}

// Raise to auto relock door
aRaiseAutoRelock = new csml.Emit {
  event = new csml.Internal { topic = "autoRelock" }
}

// Raise to return to locked state
aRaiseReturnToLock = new csml.Emit {
  event = new csml.Internal { topic = "returnToLock" }
}

// Raise to signify forced entry attempt
aRaiseForcedEntry = new csml.Emit {
  event = new csml.Global {
    topic = Events.eForcedEntry
    data {
      ["doorId"] = Vars.vDoorId
      ["zoneId"] = Vars.vZoneId
    }
  }
}
