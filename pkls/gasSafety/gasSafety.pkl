import "https://raw.githubusercontent.com/CollaborativeStateMachines/Cirrina/refs/heads/develop/src/main/resources/pkl/csm/csml.pkl"
import "../events.pkl" as Events
import "../serviceTypes.pkl" as ServiceTypes
import "../variables.pkl" as Vars
import "guards.pkl" as Guards
import "context.pkl" as Context
import "actions.pkl" as Actions

// This module contains the definition for the gasSafety SM
// gasSafety is the third part of the fire prevention system
// gasSafety detects gas leak across multiple rooms
// If a gas leak is detected, the location of that gas leak and a warning is published
sm = new csml.StateMachine {
    transient = Context.gasSafetyContext
    states {
        ["init"] = init
        ["monitoring"] = monitoring
        ["gasLeak"] = gasLeak
        ["acknowledged"] = acknowledged
    }
}

local const init: csml.Initial = new {
    always {
        new csml.Transition { to = "monitoring" }
    }
}

// Always starts in monitoring state
// Invokes gas detection service every 30 seconds
local const monitoring: csml.State = new {
    after {
        ["checkGasLeak"] = new csml.Timeout {
            delay = "30000"
            do = Actions.aRaiseStartGasLeakDetection
        }
    }
    on {
        [Events.eStartGasLeakDetection] = new csml.Transition {
            do {
                new csml.Invoke {
                    type = ServiceTypes.stCheckGasLeak
                    raises { new csml.Internal { topic = Events.eGasLeakDetectionComplete } }
                }
            }
        }
        [Events.eGasLeakDetectionComplete] = new csml.Transition {
            do {
                new csml.Eval { expression = "\(Vars.vGasLeakLocation) = $gasLeakLocation" }
                new csml.Raise { event = new csml.Internal { topic = "checkGasResult" } }
            }
        }
        ["checkGasResult"] = new csml.Transition {
            to = "gasLeak"
            iif = Guards.foundGasLeak
        }
    }
}

// Invokes close valve service and raises global gas leak event
local const gasLeak: csml.State = new {
    entry {
        new csml.Invoke {
            type = ServiceTypes.stCloseGasValve
            input {
                ["gasLeakLocation"] = Vars.vGasLeakLocation
            }
        }
        Actions.aRaiseGasLeakDetected
    }
    on {
        [Events.eGasPurged] = new csml.Transition {
            to = "acknowledged"
        }
    }
}

local const acknowledged: csml.State = new {
    entry {
        new csml.Invoke {
            type = ServiceTypes.stGasLeakPurged
        }
    }
    always {
        new csml.Transition {
            to = "monitoring"
        }
    }
}
