import
  "https://raw.githubusercontent.com/CollaborativeStateMachines/Cirrina/refs/heads/develop/src/main/resources/pkl/csm/csml.pkl"

import "../variables.pkl" as Vars

// Gas safety state machine definition.
//
// Polls for gas leaks every 30s. On detection: closes valve, cuts power,
// raises global alert. Waits for purge confirmation before resuming.
sm = new csml.StateMachine {
  transient = new Mapping { [Vars.vGasLeakLocation] = "'none'" }
  states {
    ["monitoring"] = monitoring
    ["gasLeak"] = gasLeak
    ["acknowledged"] = acknowledged
  }
}

local monitoring: csml.Initial = new {
  after {
    ["gasLeakPoll"] = new csml.Timeout {
      delay = "30000"
      triggers = new csml.Emit {
        event = new csml.Internal { topic = "startGasLeakDetection" }
      }
    }
  }
  on {
    ["startGasLeakDetection"] {
      yields {
        new csml.Invoke {
          type = "checkGasLeakService"
          emits { new csml.Internal { topic = "checkDone" } }
        }
      }
    }
    ["checkDone"] {
      yields {
        new csml.Eval { expression = "\(Vars.vGasLeakLocation) = $gasLeakLocation" }
        new csml.Match {
          cases {
            new csml.Case {
              of = "\(Vars.vGasLeakLocation) != 'none'"
              yields { new csml.Emit { event = new csml.Internal { topic = "goGasLeak" } } }
            }
          }
        }
      }
    }
    ["goGasLeak"] { to = "gasLeak" }
  }
}

// Close valve, cut power, notify.
local gasLeak: csml.State = new {
  entry {
    new csml.Invoke {
      type = "closeGasValveService"
      input { ["gasLeakLocation"] = Vars.vGasLeakLocation }
    }
    new csml.Invoke {
      type = "cutPowerService"
      input { ["gasLeakLocation"] = Vars.vGasLeakLocation }
    }
    new csml.Emit {
      event {
        topic = "gasLeakDetected"
        data {
          ["gasLeakLocation"] = Vars.vGasLeakLocation
        }
      }
    }
    new csml.Eval { expression = "\(Vars.vGasActive) = true" }
  }
  on {
    ["gasPurged"] { to = "acknowledged" }
  }
}

local acknowledged: csml.State = new {
  entry {
    new csml.Invoke { type = "gasLeakPurgedService" }
    new csml.Eval { expression = "\(Vars.vGasActive) = false" }
  }
  always {
    new csml.Transition { to = "monitoring" }
  }
}
