import "https://raw.githubusercontent.com/CollaborativeStateMachines/Cirrina/refs/heads/develop/src/main/resources/pkl/csm/csml.pkl"
import "../events.pkl" as Events
import "../serviceTypes.pkl" as ServiceTypes
import "../variables.pkl" as Vars
import "actions.pkl" as Actions
import "context.pkl" as Context
import "guards.pkl" as Guards

// Gas safety state machine definition.
//
// Polls for gas leaks every 30s. On detection: closes valve, cuts power,
// raises global alert. Waits for purge confirmation before resuming.
sm = new csml.StateMachine {
  transient = Context.gasSafetyContext
  states {
    ["monitoring"] = monitoring
    ["gasLeak"] = gasLeak
    ["acknowledged"] = acknowledged
  }
}

local monitoring: csml.Initial = new {
  after {
    ["gasLeakPoll"] = new csml.Timeout {
      delay = "30000"
      triggers = Actions.aRaiseStartGasLeakDetection
    }
  }
  on {
    [Events.eStartGasLeakDetection] {
      yields {
        new csml.Invoke {
          type = ServiceTypes.stCheckGasLeak
          emits { new csml.Internal { topic = "checkDone" } }
        }
      }
    }
    ["checkDone"] {
      yields {
        new csml.Eval { expression = "\(Vars.vGasLeakLocation) = $gasLeakLocation" }
        new csml.Match {
          cases {
            new csml.Case {
              of = Guards.foundGasLeak
              yields { new csml.Emit { event = new csml.Internal { topic = "goGasLeak" } } }
            }
          }
        }
      }
    }
    ["goGasLeak"] { to = "gasLeak" }
  }
}

// Close valve, cut power, notify.
local gasLeak: csml.State = new {
  entry {
    new csml.Invoke {
      type = ServiceTypes.stCloseGasValve
      input { ["gasLeakLocation"] = Vars.vGasLeakLocation }
    }
    new csml.Invoke {
      type = ServiceTypes.stCutPower
      input { ["gasLeakLocation"] = Vars.vGasLeakLocation }
    }
    Actions.aRaiseGasLeakDetected
    new csml.Eval { expression = "\(Vars.vGasActive) = true" }
  }
  on {
    [Events.eGasPurged] { to = "acknowledged" }
  }
}

local acknowledged: csml.State = new {
  entry {
    new csml.Invoke { type = ServiceTypes.stGasLeakPurged }
    new csml.Eval { expression = "\(Vars.vGasActive) = false" }
  }
  always {
    new csml.Transition { to = "monitoring" }
  }
}
