import "https://raw.githubusercontent.com/CollaborativeStateMachines/Cirrina/refs/heads/develop/src/main/resources/pkl/csm/csml.pkl"


import "../variables.pkl" as Vars

// HVAC state machine definition.
//
//
// Active modes poll indoor temperature periodically
sm = new csml.StateMachine {
  transient = new Mapping {
    [Vars.vIndoorTemp] = "21.0"
    [Vars.vBusinessHoursTemp] = "21.0"
    [Vars.vAfterHoursTemp] = "17.0"
    [Vars.vTempTolerance] = "1.0"
    [Vars.vDefaultTolerance] = "1.0"
    [Vars.vEnergySavingTolerance] = "3.0"
    [Vars.vDrasticSaving] = "false"
  }
  states {
    ["off"] = off
    ["fanOnly"] = fanOnly
    ["heating"] = heating
    ["cooling"] = cooling
    ["energySaving"] = energySaving
    ["emergency"] = emergency
  }
}

local off: csml.Initial = new {
  entry {
    new csml.Invoke {
      type = "setHvacService"
      input { ["mode"] = "'off'"; ["roomId"] = Vars.vRoomId }
    }
  }
  on {
    ["occupancyDetected"] { to = "fanOnly" }
    ["zoneActive"] { to = "fanOnly" }
    ["enterBusinessHours"] {
      yields { new csml.Eval { expression = "\(Vars.vDesiredTemp) = \(Vars.vBusinessHoursTemp)" } }
    }
    ["enterAfterHours"] {
      yields { new csml.Eval { expression = "\(Vars.vDesiredTemp) = \(Vars.vAfterHoursTemp)" } }
    }
    ["enterWeekend"] {
      yields { new csml.Eval { expression = "\(Vars.vDesiredTemp) = \(Vars.vAfterHoursTemp)" } }
    }
    ["energyShutdown"] { to = "emergency" }
    ["fireAlarm"] { to = "emergency" }
    ["gasLeakDetected"] { to = "emergency" }
    ["smokeAlert"] { to = "emergency" }
    ["arcFaultDetected"] { to = "emergency" }
  }
}

local fanOnly: csml.State = new {
  entry {
    new csml.Invoke {
      type = "setHvacService"
      input { ["mode"] = "'fan'"; ["roomId"] = Vars.vRoomId }
    }
    new csml.Eval { expression = "\(Vars.vTempTolerance) = \(Vars.vDefaultTolerance)" }
    new csml.Emit { event = new csml.Internal { topic = "startTempCheck" } }
  }
  after {
    ["tempPoll"] = new csml.Timeout {
      delay = "300000"
      triggers = new csml.Emit { event = new csml.Internal { topic = "startTempCheck" } }
    }
  }
  on {
    ["startTempCheck"] {
      yields {
        new csml.Invoke {
          type = "getRoomTempService"
          input { ["roomId"] = Vars.vRoomId }
          emits { new csml.Internal { topic = "tempCheckDone" } }
        }
      }
    }
    ["tempCheckDone"] {
      yields {
        new csml.Eval { expression = "\(Vars.vIndoorTemp) = $indoorTemp" }
        new csml.Match {
          cases {
            new csml.Case {
              of = "\(Vars.vIndoorTemp) < (\(Vars.vDesiredTemp) - \(Vars.vTempTolerance))"
              yields { new csml.Emit { event = new csml.Internal { topic = "goHeating" } } }
            }
            new csml.Case {
              of = "\(Vars.vIndoorTemp) > (\(Vars.vDesiredTemp) + \(Vars.vTempTolerance))"
              yields { new csml.Emit { event = new csml.Internal { topic = "goCooling" } } }
            }
          }
        }
      }
    }
    ["goHeating"] { to = "heating" }
    ["goCooling"] { to = "cooling" }
    ["occupancyVacant"] { to = "off" }
    ["zoneInactive"] { to = "off" }
    ["enterBusinessHours"] {
      yields {
        new csml.Eval { expression = "\(Vars.vDesiredTemp) = \(Vars.vBusinessHoursTemp)" }
        new csml.Emit { event = new csml.Internal { topic = "startTempCheck" } }
      }
    }
    ["enterAfterHours"] {
      yields {
        new csml.Eval { expression = "\(Vars.vDesiredTemp) = \(Vars.vAfterHoursTemp)" }
        new csml.Emit { event = new csml.Internal { topic = "startTempCheck" } }
      }
    }
    ["enterWeekend"] {
      yields {
        new csml.Eval { expression = "\(Vars.vDesiredTemp) = \(Vars.vAfterHoursTemp)" }
        new csml.Emit { event = new csml.Internal { topic = "startTempCheck" } }
      }
    }
    ["energySaving"] { to = "energySaving" }
    ["drasticEnergySaving"] { to = "energySaving" }
    ["energyShutdown"] { to = "emergency" }
    ["fireAlarm"] { to = "emergency" }
    ["gasLeakDetected"] { to = "emergency" }
    ["smokeAlert"] { to = "emergency" }
    ["arcFaultDetected"] { to = "emergency" }
  }
}

local heating: csml.State = new {
  entry {
    new csml.Invoke {
      type = "setHvacService"
      input { ["mode"] = "'heat'"; ["roomId"] = Vars.vRoomId }
    }
    new csml.Emit { event = new csml.Internal { topic = "startTempCheck" } }
  }
  after {
    ["tempPoll"] = new csml.Timeout {
      delay = "600000"
      triggers = new csml.Emit { event = new csml.Internal { topic = "startTempCheck" } }
    }
  }
  on {
    ["startTempCheck"] {
      yields {
        new csml.Invoke {
          type = "getRoomTempService"
          input { ["roomId"] = Vars.vRoomId }
          emits { new csml.Internal { topic = "tempCheckDone" } }
        }
      }
    }
    ["tempCheckDone"] {
      yields {
        new csml.Eval { expression = "\(Vars.vIndoorTemp) = $indoorTemp" }
        new csml.Match {
          cases {
            new csml.Case {
              of =
                "\(Vars.vIndoorTemp) >= (\(Vars.vDesiredTemp) - \(Vars.vTempTolerance)) && \(Vars.vIndoorTemp) <= (\(Vars.vDesiredTemp) + \(Vars.vTempTolerance))"
              yields { new csml.Emit { event = new csml.Internal { topic = "goFanOnly" } } }
            }
            new csml.Case {
              of = "\(Vars.vIndoorTemp) > (\(Vars.vDesiredTemp) + \(Vars.vTempTolerance))"
              yields { new csml.Emit { event = new csml.Internal { topic = "goCooling" } } }
            }
          }
        }
      }
    }
    ["goFanOnly"] { to = "fanOnly" }
    ["goCooling"] { to = "cooling" }
    ["occupancyVacant"] { to = "off" }
    ["zoneInactive"] { to = "off" }
    ["enterBusinessHours"] {
      yields {
        new csml.Eval { expression = "\(Vars.vDesiredTemp) = \(Vars.vBusinessHoursTemp)" }
        new csml.Emit { event = new csml.Internal { topic = "startTempCheck" } }
      }
    }
    ["enterAfterHours"] {
      yields {
        new csml.Eval { expression = "\(Vars.vDesiredTemp) = \(Vars.vAfterHoursTemp)" }
        new csml.Emit { event = new csml.Internal { topic = "startTempCheck" } }
      }
    }
    ["enterWeekend"] {
      yields {
        new csml.Eval { expression = "\(Vars.vDesiredTemp) = \(Vars.vAfterHoursTemp)" }
        new csml.Emit { event = new csml.Internal { topic = "startTempCheck" } }
      }
    }
    ["energySaving"] { to = "energySaving" }
    ["drasticEnergySaving"] { to = "energySaving" }
    ["energyShutdown"] { to = "emergency" }
    ["fireAlarm"] { to = "emergency" }
    ["gasLeakDetected"] { to = "emergency" }
    ["smokeAlert"] { to = "emergency" }
    ["arcFaultDetected"] { to = "emergency" }
  }
}

local cooling: csml.State = new {
  entry {
    new csml.Invoke {
      type = "setHvacService"
      input { ["mode"] = "'cool'"; ["roomId"] = Vars.vRoomId }
    }
    new csml.Emit { event = new csml.Internal { topic = "startTempCheck" } }
  }
  after {
    ["tempPoll"] = new csml.Timeout {
      delay = "600000"
      triggers = new csml.Emit { event = new csml.Internal { topic = "startTempCheck" } }
    }
  }
  on {
    ["startTempCheck"] {
      yields {
        new csml.Invoke {
          type = "getRoomTempService"
          input { ["roomId"] = Vars.vRoomId }
          emits { new csml.Internal { topic = "tempCheckDone" } }
        }
      }
    }
    ["tempCheckDone"] {
      yields {
        new csml.Eval { expression = "\(Vars.vIndoorTemp) = $indoorTemp" }
        new csml.Match {
          cases {
            new csml.Case {
              of =
                "\(Vars.vIndoorTemp) >= (\(Vars.vDesiredTemp) - \(Vars.vTempTolerance)) && \(Vars.vIndoorTemp) <= (\(Vars.vDesiredTemp) + \(Vars.vTempTolerance))"
              yields { new csml.Emit { event = new csml.Internal { topic = "goFanOnly" } } }
            }
            new csml.Case {
              of = "\(Vars.vIndoorTemp) < (\(Vars.vDesiredTemp) - \(Vars.vTempTolerance))"
              yields { new csml.Emit { event = new csml.Internal { topic = "goHeating" } } }
            }
          }
        }
      }
    }
    ["goFanOnly"] { to = "fanOnly" }
    ["goHeating"] { to = "heating" }
    ["occupancyVacant"] { to = "off" }
    ["zoneInactive"] { to = "off" }
    ["enterBusinessHours"] {
      yields {
        new csml.Eval { expression = "\(Vars.vDesiredTemp) = \(Vars.vBusinessHoursTemp)" }
        new csml.Emit { event = new csml.Internal { topic = "startTempCheck" } }
      }
    }
    ["enterAfterHours"] {
      yields {
        new csml.Eval { expression = "\(Vars.vDesiredTemp) = \(Vars.vAfterHoursTemp)" }
        new csml.Emit { event = new csml.Internal { topic = "startTempCheck" } }
      }
    }
    ["enterWeekend"] {
      yields {
        new csml.Eval { expression = "\(Vars.vDesiredTemp) = \(Vars.vAfterHoursTemp)" }
        new csml.Emit { event = new csml.Internal { topic = "startTempCheck" } }
      }
    }
    ["energySaving"] { to = "energySaving" }
    ["drasticEnergySaving"] { to = "energySaving" }
    ["energyShutdown"] { to = "emergency" }
    ["fireAlarm"] { to = "emergency" }
    ["gasLeakDetected"] { to = "emergency" }
    ["smokeAlert"] { to = "emergency" }
    ["arcFaultDetected"] { to = "emergency" }
  }
}

local energySaving: csml.State = new {
  entry {
    new csml.Invoke {
      type = "setHvacService"
      input { ["mode"] = "'fan'"; ["roomId"] = Vars.vRoomId }
    }
    new csml.Eval { expression = "\(Vars.vTempTolerance) = \(Vars.vEnergySavingTolerance)" }
    new csml.Emit { event = new csml.Internal { topic = "startTempCheck" } }
  }
  after {
    ["tempPoll"] = new csml.Timeout {
      delay = "900000"
      triggers = new csml.Emit { event = new csml.Internal { topic = "startTempCheck" } }
    }
  }
  on {
    ["startTempCheck"] {
      yields {
        new csml.Invoke {
          type = "getRoomTempService"
          input { ["roomId"] = Vars.vRoomId }
          emits { new csml.Internal { topic = "tempCheckDone" } }
        }
      }
    }
    ["tempCheckDone"] {
      provided = "!\(Vars.vDrasticSaving)"
      yields {
        new csml.Eval { expression = "\(Vars.vIndoorTemp) = $indoorTemp" }
        new csml.Match {
          cases {
            new csml.Case {
              of = "\(Vars.vIndoorTemp) < (\(Vars.vDesiredTemp) - \(Vars.vTempTolerance))"
              yields { new csml.Emit { event = new csml.Internal { topic = "goHeating" } } }
            }
            new csml.Case {
              of = "\(Vars.vIndoorTemp) > (\(Vars.vDesiredTemp) + \(Vars.vTempTolerance))"
              yields { new csml.Emit { event = new csml.Internal { topic = "goCooling" } } }
            }
          }
        }
      }
    }
    ["goHeating"] { to = "heating" }
    ["goCooling"] { to = "cooling" }
    ["drasticEnergySaving"] {
      yields {
        new csml.Eval { expression = "\(Vars.vDrasticSaving) = true" }
      }
    }
    ["deactivateEnergySaving"] { to = "fanOnly" }
    ["occupancyVacant"] { to = "off" }
    ["zoneInactive"] { to = "off" }
    ["enterBusinessHours"] {
      yields { new csml.Eval { expression = "\(Vars.vDesiredTemp) = \(Vars.vBusinessHoursTemp)" } }
    }
    ["enterAfterHours"] {
      yields { new csml.Eval { expression = "\(Vars.vDesiredTemp) = \(Vars.vAfterHoursTemp)" } }
    }
    ["enterWeekend"] {
      yields { new csml.Eval { expression = "\(Vars.vDesiredTemp) = \(Vars.vAfterHoursTemp)" } }
    }
    ["energyShutdown"] { to = "emergency" }
    ["fireAlarm"] { to = "emergency" }
    ["gasLeakDetected"] { to = "emergency" }
    ["smokeAlert"] { to = "emergency" }
    ["arcFaultDetected"] { to = "emergency" }
  }
}

local emergency: csml.State = new {
  entry {
    new csml.Invoke {
      type = "setHvacService"
      input { ["mode"] = "'off'"; ["roomId"] = Vars.vRoomId }
    }
    new csml.Eval { expression = "\(Vars.vDrasticSaving) = false" }
    new csml.Eval { expression = "\(Vars.vTempTolerance) = \(Vars.vDefaultTolerance)" }
  }
  on {
    ["disarmFireAlarm"] {
      to = "off"
      provided =
        "!\(Vars.vFireAlarm) && !\(Vars.vGasActive) && !\(Vars.vSmokeAlert) && !\(Vars.vArcFault)"
    }
    ["gasPurged"] {
      to = "off"
      provided =
        "!\(Vars.vFireAlarm) && !\(Vars.vGasActive) && !\(Vars.vSmokeAlert) && !\(Vars.vArcFault)"
    }
    ["disarmSmokeAlert"] {
      to = "off"
      provided =
        "!\(Vars.vFireAlarm) && !\(Vars.vGasActive) && !\(Vars.vSmokeAlert) && !\(Vars.vArcFault)"
    }
    ["electricalReset"] {
      to = "off"
      provided =
        "!\(Vars.vFireAlarm) && !\(Vars.vGasActive) && !\(Vars.vSmokeAlert) && !\(Vars.vArcFault)"
    }
  }
}
