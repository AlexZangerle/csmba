import "https://raw.githubusercontent.com/CollaborativeStateMachines/Cirrina/refs/heads/develop/src/main/resources/pkl/csm/csml.pkl"
import "../events.pkl" as Events
import "actions.pkl" as Actions
import "context.pkl" as Context
import "guards.pkl" as Guards
import "../serviceTypes.pkl" as ServiceTypes
import "../variables.pkl" as Vars

// This module contains the definition for the HVAC SM
sm = new csml.StateMachine {
  transient = Context.hvacContext
  states {
    ["init"] = init
    ["off"] = off
    ["fanOnly"] = fanOnly
    ["fanOnlyLoop"] = fanOnlyLoop
    ["checkCoolingFan"] = checkCoolingFan
    ["heating"] = heating
    ["heatingLoop"] = heatingLoop
    ["checkOverheat"] = checkOverheat
    ["cooling"] = cooling
    ["coolingLoop"] = coolingLoop
    ["checkOvercool"] = checkOvercool
    ["emergency"] = emergency
  }
}

local const init: csml.Initial = new {
  always {
    new csml.Transition { to = "off" }
  }
}

// Default state when zone inactive or vacant.
local const off: csml.State = new {
  entry {
    new csml.Invoke {
      type = ServiceTypes.stSetHVAC
      input { ["mode"] = "'off'" }
    }
  }
  on {
    [Events.eOccupancyDetected] = new csml.Transition { to = "fanOnly" }
    [Events.eZoneActive] = new csml.Transition { to = "fanOnly"; iif = Guards.isMyZone }
    [Events.eFireAlarm] = new csml.Transition { to = "emergency" }
    [Events.eGasLeakDetected] = new csml.Transition { to = "emergency" }
  }
}

// Start State: Sets mode and triggers first check
local const fanOnly: csml.State = new {
  entry {
    new csml.Invoke { type = ServiceTypes.stSetHVAC input { ["mode"] = "'fan'" } }
    Actions.aRaiseIndoorTempCheck
  }
  always {
    new csml.Transition { to = "fanOnlyLoop" }
  }
}

// Loop State: Handles periodic checks.
local const fanOnlyLoop: csml.State = new {
  after {
    ["periodicTempCheck"] = new csml.Timeout {
      delay = "300000" // 5 min
      do = Actions.aRaiseIndoorTempCheck
    }
  }
  on {
    [Events.eStartIndoorTempCheck] = new csml.Transition {
      do {
        new csml.Invoke {
          type = ServiceTypes.stGetIndoorTemp
          raises { new csml.Internal { topic = Events.eIndoorTempCheckComplete } }
        }
      }
    }
    [Events.eIndoorTempCheckComplete] = new csml.Transition {
      do {
        new csml.Eval { expression = "\(Vars.vIndoorTemp) = $indoorTemp" }
        new csml.Raise { event = new csml.Internal { topic = "checkHeating" } }
      }
    }
    ["checkHeating"] = new csml.Transition {
      to = "heating"
      iif = Guards.roomToCold
      or = "checkCoolingFan"
    }
    [Events.eOccupancyVacant] = new csml.Transition { to = "off" }
    [Events.eZoneInactive] = new csml.Transition { to = "off"; iif = Guards.isMyZone }
    [Events.eFireAlarm] = new csml.Transition { to = "emergency" }
    [Events.eGasLeakDetected] = new csml.Transition { to = "emergency" }
  }
}

// Helper: Check Cooling or Return to Loop
local const checkCoolingFan: csml.State = new {
  always {
    new csml.Transition {
      to = "cooling"
      iif = Guards.roomToHot
      or = "fanOnlyLoop"
    }
  }
}

// Statet to start heating
local const heating: csml.State = new {
  entry {
    new csml.Invoke { type = ServiceTypes.stSetHVAC input { ["mode"] = "'heat'" } }
    Actions.aRaiseIndoorTempCheck
  }
  always { new csml.Transition { to = "heatingLoop" } }
}

// Loop State for re-checking
local const heatingLoop: csml.State = new {
  after {
    ["periodicTempCheck"] = new csml.Timeout {
      delay = "600000"
      do = Actions.aRaiseIndoorTempCheck
    }
  }
  on {
    [Events.eStartIndoorTempCheck] = new csml.Transition {
      do {
        new csml.Invoke {
          type = ServiceTypes.stGetIndoorTemp
          raises { new csml.Internal { topic = Events.eIndoorTempCheckComplete } }
        }
      }
    }
    [Events.eIndoorTempCheckComplete] = new csml.Transition {
      do {
        new csml.Eval { expression = "\(Vars.vIndoorTemp) = $indoorTemp" }
        new csml.Raise { event = new csml.Internal { topic = "checkComfort" } }
      }
    }

    ["checkComfort"] = new csml.Transition {
      to = "fanOnly"
      iif = Guards.roomComfortable
      or = "checkOverheat"
    }

    [Events.eOccupancyVacant] = new csml.Transition { to = "off" }
    [Events.eZoneInactive] = new csml.Transition { to = "off"; iif = Guards.isMyZone }
    [Events.eFireAlarm] = new csml.Transition { to = "emergency" }
    [Events.eGasLeakDetected] = new csml.Transition { to = "emergency" }
  }
}

// Check Overshoot or Return to Loop
local const checkOverheat: csml.State = new {
  always {
    new csml.Transition {
      to = "cooling"
      iif = Guards.roomToHot
      or = "heatingLoop" // Keep heating
    }
  }
}

// Start Cooling State
local const cooling: csml.State = new {
  entry {
    new csml.Invoke { type = ServiceTypes.stSetHVAC input { ["mode"] = "'cool'" } }
    Actions.aRaiseIndoorTempCheck
  }
  always { new csml.Transition { to = "coolingLoop" } }
}

// Loop State for re-check
local const coolingLoop: csml.State = new {
  after {
    ["periodicTempCheck"] = new csml.Timeout {
      delay = "600000"
      do = Actions.aRaiseIndoorTempCheck
    }
  }
  on {
    [Events.eStartIndoorTempCheck] = new csml.Transition {
      do {
        new csml.Invoke {
          type = ServiceTypes.stGetIndoorTemp
          raises { new csml.Internal { topic = Events.eIndoorTempCheckComplete } }
        }
      }
    }
    [Events.eIndoorTempCheckComplete] = new csml.Transition {
      do {
        new csml.Eval { expression = "\(Vars.vIndoorTemp) = $indoorTemp" }
        new csml.Raise { event = new csml.Internal { topic = "checkComfort" } }
      }
    }

    ["checkComfort"] = new csml.Transition {
      to = "fanOnly"
      iif = Guards.roomComfortable
      or = "checkOvercool"
    }

    [Events.eOccupancyVacant] = new csml.Transition { to = "off" }
    [Events.eZoneInactive] = new csml.Transition { to = "off"; iif = Guards.isMyZone }
    [Events.eFireAlarm] = new csml.Transition { to = "emergency" }
    [Events.eGasLeakDetected] = new csml.Transition { to = "emergency" }
  }
}

// Check Overshoot or Return to Loop
local const checkOvercool: csml.State = new {
  always {
    new csml.Transition {
      to = "heating"
      iif = Guards.roomToCold
      or = "coolingLoop" // Keep cooling
    }
  }
}

// emergency state shutting off hvac systems
local const emergency: csml.State = new {
  entry {
    new csml.Invoke { type = ServiceTypes.stSetHVAC input { ["mode"] = "'off'" } }
  }
  on {
    [Events.eDisarmFireAlarm] = new csml.Transition { to = "off" }
    [Events.eGasPurged] = new csml.Transition { to = "off" }
  }
}
