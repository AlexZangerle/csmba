import "../variables.pkl" as Vars

// This module contains all guards for hvacSM

// Guard to check if the room is too cold (below desired - tolerance)
roomToCold = "\(Vars.vIndoorTemp) < (\(Vars.vDesiredTemp) - \(Vars.vTempTolerance))"

// Guard to check if the room is too hot (above desired + tolerance)
roomToHot = "\(Vars.vIndoorTemp) > (\(Vars.vDesiredTemp) + \(Vars.vTempTolerance))"

// Guard to check if desired temperature has been reached (within tolerance band)
roomComfortable = "\(Vars.vIndoorTemp) >= (\(Vars.vDesiredTemp) - \(Vars.vTempTolerance)) && \(Vars.vIndoorTemp) <= (\(Vars.vDesiredTemp) + \(Vars.vTempTolerance))"

// Guard to check if drastic energy saving is not active
isNotDrasticSaving = "!\(Vars.vDrasticSaving)"

isSafeToExitEmergency = "!\(Vars.vFireAlarm) && !\(Vars.vGasActive) && !\(Vars.vSmokeAlert) && !\(Vars.vArcFault)"