import "../variables.pkl" as Vars
import "https://raw.githubusercontent.com/CollaborativeStateMachines/Cirrina/refs/heads/develop/src/main/resources/pkl/csm/csml.pkl"

// This module contains all guards for hvacSM

// Guard to check if the room is too cold
roomToCold = "\(Vars.vIndoorTemp) < \(Vars.vDesiredTemp)"


// Guard to check if the room is too hot
roomToHot = "\(Vars.vIndoorTemp) > \(Vars.vDesiredTemp)"


// Guard to check if desired temperature has been matched
roomComfortable = "\(Vars.vIndoorTemp) == \(Vars.vDesiredTemp)"


// Guard to check if event carries the current zone as data
isMyZone = "$zoneId == \(Vars.vZoneId)"

