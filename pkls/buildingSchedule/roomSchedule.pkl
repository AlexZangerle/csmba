import "https://raw.githubusercontent.com/CollaborativeStateMachines/Cirrina/refs/heads/develop/src/main/resources/pkl/csm/csml.pkl"
import "../events.pkl" as Events
import "../serviceTypes.pkl" as ServiceTypes
import "actions.pkl" as Actions
import "context.pkl" as Context
import "guards.pkl" as Guards

// Room schedule state machine definition.
//
// Manages per-room/zone lifecycle based on the global building schedule.
// Handles user override requests for extended stays and safety emergencies.
sm = new csml.StateMachine {
  transient = Context.roomContext
  states {
    ["init"] = init
    ["active"] = active
    ["inactive"] = inactive
    ["warning"] = warning
    ["authorizedStay"] = authorizedStay
    ["emergency"] = emergency
  }
}

// Initializes zone
local init: csml.Initial = new {
  entry {
    new csml.Invoke {
      type = ServiceTypes.stInitializeZone
      emits { new csml.Internal { topic = "zoneInitialized" } }
    }
  }
  on {
    ["zoneInitialized"] { to = "inactive" }
  }
}

local active: csml.State = new {
  entry {
    Actions.aRaiseZoneActive
  }
  on {
    [Events.eEnterAfterHoursMode] { to = "warning" }
    [Events.eEnterWeekend] { to = "warning" }
    [Events.eFireAlarm] { to = "emergency" }
    [Events.eGasLeakDetected] { to = "emergency" }
  }
}

local inactive: csml.State = new {
  entry {
    Actions.aRaiseZoneInactive
  }
  on {
    [Events.eEnterBusinessHours] { to = "active" }
    [Events.eRequestStay] { to = "authorizedStay"; provided = Guards.requestedStay }
    [Events.eFireAlarm] { to = "emergency" }
    [Events.eGasLeakDetected] { to = "emergency" }
  }
}

// 5-minute grace period before shutting down the room.
local warning: csml.State = new {
  entry {
    Actions.aRaiseZoneWarning
  }
  after {
    ["gracePeriod"] = new csml.Timeout {
      delay = "300000"
      triggers = Actions.aRaiseShutdownRoom
    }
  }
  on {
    [Events.eShutdownRoom] { to = "inactive" }
    [Events.eRequestStay] { to = "authorizedStay"; provided = Guards.requestedStay }
    [Events.eEnterBusinessHours] { to = "active" }
    [Events.eFireAlarm] { to = "emergency" }
    [Events.eGasLeakDetected] { to = "emergency" }
  }
}

// 2-hour lease; re-enters warning when expired.
local authorizedStay: csml.State = new {
  entry {
    Actions.aRaiseZoneActive
  }
  after {
    ["overrideLease"] = new csml.Timeout {
      delay = "7200000"
      triggers = Actions.aRaiseRecheckOverride
    }
  }
  on {
    [Events.eRecheckOverride] { to = "warning" }
    [Events.eUserLeftZone] { to = "inactive"; provided = Guards.userLeftZone }
    [Events.eEnterBusinessHours] { to = "active" }
    [Events.eFireAlarm] { to = "emergency" }
    [Events.eGasLeakDetected] { to = "emergency" }
  }
}

// Safety protocols override all schedules.
local emergency: csml.State = new {
  on {
    [Events.eDisarmFireAlarm] {
      to = "inactive"
      provided = Guards.isSafeToExitEmergency
    }
    [Events.eGasPurged] {
      to = "inactive"
      provided = Guards.isSafeToExitEmergency
    }
  }
}
