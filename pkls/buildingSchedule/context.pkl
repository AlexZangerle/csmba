import "https://raw.githubusercontent.com/AlexZangerle/csmba/main/pkls/variables.pkl" as Vars
import "https://raw.githubusercontent.com/CollaborativeStateMachines/Cirrina/refs/heads/develop/src/main/resources/pkl/csm/csml.pkl"

// This module contains all contexts for the buildingSchedule SM and roomScheduleSM
// buildingScheduleContext includes the currentScheduleMode
scheduleContext = new Mapping {
  [Vars.vCurrentScheduleMode] = "''"
}

// roomScheduleContext contains the zoneId of the corresponding room
roomContext = new Mapping {
  [Vars.vZoneId] = "'testZone'"
}

