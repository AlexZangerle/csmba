import "https://raw.githubusercontent.com/AlexZangerle/csmba/main/pkls/variables.pkl" as Vars
import "https://raw.githubusercontent.com/CollaborativeStateMachines/Cirrina/refs/heads/develop/src/main/resources/pkl/csm/csml.pkl"
// This module contains all guards for buildingScheduleSM and roomScheduleSM

// Guard to check if building is in businessHours
isBusinessHours = "\(Vars.vCurrentScheduleMode) == 'businessHours'"

// Guard to check if building is in afterHours
isAfterHours = "\(Vars.vCurrentScheduleMode) == 'afterHours'"

// Guard to check if building is in weekend
isWeekend = "\(Vars.vCurrentScheduleMode) == 'weekendClosed'"

// Guard to check if an extended stay has been requested for this zone
requestedStay = "$zoneId == \(Vars.vZoneId)"


// Guard to check if user left this zone
userLeftZone = "$zoneId == \(Vars.vZoneId)"

