import "actions.pkl" as Actions
import "context.pkl" as Context
import "guards.pkl" as Guards
import "../events.pkl" as Events
import "../serviceTypes.pkl" as ServiceTypes
import "../variables.pkl" as Vars
import "https://raw.githubusercontent.com/CollaborativeStateMachines/Cirrina/refs/heads/develop/src/main/resources/pkl/csm/csml.pkl"

/// This module defines the buildingScheduleSM
sm = new csml.StateMachine {
  transient = Context.scheduleContext
  states {
    ["init"] = init
    ["evaluating"] = evaluating
    ["evaluateSchedule"] = evaluateSchedule
    ["businessHours"] = businessHours
    ["afterHours"] = afterHours
    ["weekendClosed"] = weekendClosed
    ["emergencyOverride"] = emergencyOverride
  }
}

local const init: csml.Initial = new {
  always {
    new csml.Transition { to = "evaluating"}
  }
}

/// The central state calling the time service and routing to the corresponding operational mode.
local const evaluating: csml.State = new {
  entry {
    new csml.Invoke {
      type = ServiceTypes.stGetScheduleMode
      raises { new csml.Internal { topic = Events.eScheduleCheckComplete}}
    }
  }
  on {
    [Events.eScheduleCheckComplete] = new csml.Transition {
      do {
        new csml.Eval { expression = "\(Vars.vCurrentScheduleMode) = $currentSchedule"}
        new csml.Raise { event = new csml.Global { topic = Events.eCheckIsWeekend }}
      }
    }
    [Events.eCheckIsWeekend] = new csml.Transition {
      to = "weekendClosed"
      iif = Guards.isWeekend
      or = "evaluateSchedule"
    }
  }
}

local const evaluateSchedule: csml.State = new {
  always {
    new csml.Transition {
      to = "businessHours"
      iif = Guards.isBusinessHours
      or = "afterHours"
    }
  }
}

/// The state signifying that the building is currently in its normal operating hours
/// Re-checks every 15 minutes
local const businessHours: csml.State = new {
  entry {
    Actions.aRaiseEnterBusinessHours
  }
  after {
    ["scheduleCheck"] = new csml.Timeout {
      delay = "900000"
      do = Actions.aRaiseStartScheduleCheck
    }
  }
  on {
    [Events.eStartScheduleCheck] = new csml.Transition {
      to = "evaluating"
    }
    [Events.eFireAlarm] = new csml.Transition {
      to = "emergencyOverride"
    }
  }
}


/// State to signify the building is currently between businessHours on a weekday
local const afterHours: csml.State = new {
  entry {
    Actions.aRaiseEnterAfterHours
  }
  after {
    ["scheduleCheck"] = new csml.Timeout {
      delay = "900000"
      do = Actions.aRaiseStartScheduleCheck
    }
  }
  on {
    [Events.eStartScheduleCheck] = new csml.Transition {
      to = "evaluating"
    }
    [Events.eFireAlarm] = new csml.Transition {
      to = "emergencyOverride"
    }
  }
}

/// State to signify it is currently weekend
/// Less frequent schedule check
local const weekendClosed: csml.State = new {
  entry {
    Actions.aRaiseEnterWeekend
  }
  after {
    ["scheduleCheck"] = new csml.Timeout {
      delay = "900000"
      do = Actions.aRaiseStartScheduleCheck
    }
  }
  on {
    [Events.eStartScheduleCheck] = new csml.Transition {
      to = "evaluating"
    }
    [Events.eFireAlarm] = new csml.Transition {
      to = "emergencyOverride"
    }
  }
}

/// State signifying the building is currently in an emergency
local const emergencyOverride: csml.State = new {
  on {
    [Events.eDisarmFireAlarm] = new csml.Transition {
      to = "evaluating"
    }
    [Events.eGasPurged] = new csml.Transition {
      to = "evaluating"
    }
  }
}
