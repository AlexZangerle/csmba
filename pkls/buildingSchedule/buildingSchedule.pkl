import "https://raw.githubusercontent.com/CollaborativeStateMachines/Cirrina/refs/heads/develop/src/main/resources/pkl/csm/csml.pkl"
import "../events.pkl" as Events
import "../serviceTypes.pkl" as ServiceTypes
import "../variables.pkl" as Vars
import "actions.pkl" as Actions
import "context.pkl" as Context
import "guards.pkl" as Guards

// Building schedule state machine definition.
//
// Periodically checks a schedule service to determine the current
// operational mode: businessHours | afterHours | weekendClosed.
// Each mode re-evaluates on a timer (15 min weekday, 2 hr weekend).
sm = new csml.StateMachine {
  transient = Context.scheduleContext
  states {
    ["evaluating"] = evaluating
    ["businessHours"] = businessHours
    ["afterHours"] = afterHours
    ["weekendClosed"] = weekendClosed
    ["emergencyOverride"] = emergencyOverride
  }
}

// Fetches current schedule from the time service
local evaluating: csml.Initial = new {
  entry {
    new csml.Invoke {
      type = ServiceTypes.stGetScheduleMode
      emits { new csml.Internal { topic = "scheduleCheckDone" } }
    }
  }
  on {
    ["scheduleCheckDone"] {
      yields {
        new csml.Assign { expression = "\(Vars.vCurrentScheduleMode) = $currentSchedule" }
        new csml.Match {
          cases {
            new csml.Case {
              of = Guards.isWeekend
              yields { new csml.Emit { event = new csml.Internal { topic = "goWeekend" } } }
            }
            new csml.Case {
              of = Guards.isBusinessHours
              yields { new csml.Emit { event = new csml.Internal { topic = "goBusiness" } } }
            }
          }
          default = new csml.Emit { event = new csml.Internal { topic = "goAfterHours" } }
        }
      }
    }
    ["goWeekend"] { to = "weekendClosed" }
    ["goBusiness"] { to = "businessHours" }
    ["goAfterHours"] { to = "afterHours" }
    [Events.eFireAlarm] { to = "emergencyOverride" }
    [Events.eGasLeakDetected] { to = "emergencyOverride" }
  }
}

// Re-checks every 15 minutes.
local businessHours: csml.State = new {
  entry { Actions.aRaiseEnterBusinessHours }
  after {
    ["scheduleCheck"] = new csml.Timeout {
      delay = "900000"
      triggers = Actions.aRaiseStartScheduleCheck
    }
  }
  on {
    [Events.eStartScheduleCheck] { to = "evaluating" }
    [Events.eFireAlarm] { to = "emergencyOverride" }
    [Events.eGasLeakDetected] { to = "emergencyOverride" }
  }
}

local afterHours: csml.State = new {
  entry {
    Actions.aRaiseEnterAfterHours
  }
  after {
    ["scheduleCheck"] = new csml.Timeout {
      delay = "900000"
      triggers = Actions.aRaiseStartScheduleCheck
    }
  }
  on {
    [Events.eStartScheduleCheck] { to = "evaluating" }
    [Events.eFireAlarm] { to = "emergencyOverride" }
    [Events.eGasLeakDetected] { to = "emergencyOverride" }
  }
}

// Re-checks every 2 hours.
local weekendClosed: csml.State = new {
  entry {
    Actions.aRaiseEnterWeekend
  }
  after {
    ["scheduleCheck"] = new csml.Timeout {
      delay = "7200000"
      triggers = Actions.aRaiseStartScheduleCheck
    }
  }
  on {
    [Events.eStartScheduleCheck] { to = "evaluating" }
    [Events.eFireAlarm] { to = "emergencyOverride" }
    [Events.eGasLeakDetected] { to = "emergencyOverride" }
  }
}

local emergencyOverride: csml.State = new {
  on {
    [Events.eDisarmFireAlarm] {
      to = "evaluating"
      provided = Guards.isSafeToExitEmergency
    }
    [Events.eGasPurged] {
      to = "evaluating"
      provided = Guards.isSafeToExitEmergency
    }
  }
}
