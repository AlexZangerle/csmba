import "https://raw.githubusercontent.com/AlexZangerle/csmba/main/pkls/events.pkl" as Events
import "https://raw.githubusercontent.com/AlexZangerle/csmba/main/pkls/variables.pkl" as Vars
import "https://raw.githubusercontent.com/CollaborativeStateMachines/Cirrina/refs/heads/develop/src/main/resources/pkl/csm/csml.pkl"


// This module contains actions for the buildingScheduleSM and roomScheduleSM

// Raise to signal entry of business hours
aRaiseEnterBusinessHours = new csml.Emit { event { topic = Events.eEnterBusinessHours } }

// Raise to start a schedule check
aRaiseStartScheduleCheck = new csml.Emit { event = new csml.Internal { topic = Events.eStartScheduleCheck } }

// Raise to signal entry of after hours
aRaiseEnterAfterHours = new csml.Emit { event { topic = Events.eEnterAfterHoursMode } }

// Raise to signal entry of weekend
aRaiseEnterWeekend = new csml.Emit { event { topic = Events.eEnterWeekend } }

// Raise to signify activation of zone
aRaiseZoneActive = new csml.Emit {
  event {
    topic = Events.eZoneActive
    data { ["zoneId"] = Vars.vZoneId }
  }
}


// Raise to signify deactivation of zone
aRaiseZoneInactive = new csml.Emit {
  event {
    topic = Events.eZoneInactive
    data { ["zoneId"] = Vars.vZoneId }
  }
}


// Raise to signify the zone entering a warning state
aRaiseZoneWarning = new csml.Emit {
  event {
    topic = Events.eZoneWarning
    data { ["zoneId"] = Vars.vZoneId }
  }
}

// Raise to put room to inactive
aRaiseShutdownRoom = new csml.Emit {
  event = new csml.Internal { topic = Events.eShutdownRoom }
}

// Raise to recheck override
aRaiseRecheckOverride = new csml.Emit {
  event = new csml.Internal { topic = Events.eRecheckOverride }
}
