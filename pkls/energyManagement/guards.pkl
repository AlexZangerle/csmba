import "../variables.pkl" as Vars
import "https://raw.githubusercontent.com/CollaborativeStateMachines/Cirrina/refs/heads/develop/src/main/resources/pkl/csm/Csml.pkl"

// This module contains all guards for energyManagement SM

// Guard to check if gridStatus is demandResponse
gridDemandResponse = "\(Vars.vGridStatus) == 'demandResponse'"


// Guard to check if gridStatus is normal
gridNormal = "\(Vars.vGridStatus) == 'normal'"


// Guard to check if current energy price is above maximum
priceAboveMax = "\(Vars.vEnergyPrice) > \(Vars.vMaxEnergyPrice)"


// Guard to check if current energy price is under maximum
priceUnderMax = "\(Vars.vEnergyPrice) <= \(Vars.vMaxEnergyPrice)"

//  Guard to check if building is in business hours
isBusinessHours = "\(Vars.vCurrentSystemScheduleMode) == 'businessHours'"


// Guard to check for high severity security breach
isHighSeverityBreach = "$level == 'High'"
