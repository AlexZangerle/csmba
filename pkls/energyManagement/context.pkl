import "../variables.pkl" as Vars
import "https://raw.githubusercontent.com/CollaborativeStateMachines/Cirrina/refs/heads/develop/src/main/resources/pkl/csm/Csml.pkl"
// This module contains all contexts for the energyManagement SM

// Context contains variables for energy price and grid status
energyManagementContext = new Mapping {
  [Vars.vEnergyPrice] = "'0'"
  [Vars.vGridStatus] = "'normal'"
  [Vars.vCurrentSystemScheduleMode] = "'unknown'"
}
