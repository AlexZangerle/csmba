import "https://raw.githubusercontent.com/CollaborativeStateMachines/Cirrina/refs/heads/develop/src/main/resources/pkl/csm/csml.pkl"
import "actions.pkl" as Actions
import "context.pkl" as Context
import "guards.pkl" as Guards
import "../events.pkl" as Events
import "../serviceTypes.pkl" as ServiceTypes
import "../variables.pkl" as Vars

// This module contains the definition for the energyManagement SM
sm = new csml.StateMachine {
  transient = Context.energyManagementContext
  states {
    ["init"] = init
    ["normal"] = normal
    ["fetchingGridStatus"] = fetchingGridStatus
    ["evaluatingStatus"] = evaluatingStatus
    ["checkPeak"] = checkPeak
    ["peak"] = peak
    ["gridRequestResponse"] = gridRequestResponse
  }
}

local const init: csml.Initial = new {
  always {
    new csml.Transition { to = "normal" }
  }
}

// Normal mode - Energy saving generally inactive.
local const normal: csml.State = new {
  entry {
    Actions.aRaiseDeactiveEnergySaving
  }
  after {
    ["energyCheck"] = new csml.Timeout {
      delay = "30000"
      do = Actions.aRaiseStartDetectingEnergy
    }
  }
  on {
    [Events.eStartEnergyCheck] = new csml.Transition {
      do {
        new csml.Invoke {
          type = ServiceTypes.stGetEnergyPrice
          raises { new csml.Internal { topic = "priceCheckComplete" } }
        }
      }
    }
    ["priceCheckComplete"] = new csml.Transition {
      do {
        new csml.Eval { expression = "\(Vars.vEnergyPrice) = $energyPrice" }
      }
      to = "fetchingGridStatus"
    }
    [Events.eEnterBusinessHours] = new csml.Transition {
      do { new csml.Eval { expression = "\(Vars.vCurrentSystemScheduleMode) = 'businessHours'" } }
    }
    [Events.eEnterAfterHoursMode] = new csml.Transition {
      do { new csml.Eval { expression = "\(Vars.vCurrentSystemScheduleMode) = 'afterHours'" } }
    }
    [Events.eEnterWeekend] = new csml.Transition {
      do { new csml.Eval { expression = "\(Vars.vCurrentSystemScheduleMode) = 'weekendClosed'" } }
    }
  }
}

// Intermediate State: Fetch Grid Status
local const fetchingGridStatus: csml.State = new {
  entry {
    new csml.Invoke {
      type = ServiceTypes.stCheckGridStatus
      raises { new csml.Internal { topic = Events.eEnergyCheckComplete } }
    }
  }
  on {
    [Events.eEnergyCheckComplete] = new csml.Transition {
      do {
        new csml.Eval { expression = "\(Vars.vGridStatus) = $gridStatus" }
        new csml.Raise { event = new csml.Internal { topic = "processEnergyStatus" } }
      }
    }
    ["processEnergyStatus"] = new csml.Transition {
      to = "evaluatingStatus"
    }
    // Safety Overrides
    [Events.eFireAlarm] = new csml.Transition { to = "normal" }
    [Events.eGasLeakDetected] = new csml.Transition { to = "normal" }
    [Events.eSecurityBreachNotification] = new csml.Transition {
      to = "normal"
      iif = Guards.isHighSeverityBreach
    }
  }
}

// Route based on data
local const evaluatingStatus: csml.State = new {
  always {
    new csml.Transition {
      to = "gridRequestResponse"
      iif = Guards.gridDemandResponse
      or = "checkPeak"
    }
  }
}

// Helper state for Branching
local const checkPeak: csml.State = new {
  always {
    new csml.Transition {
      to = "peak"
      iif = Guards.priceAboveMax
      or = "normal"
    }
  }
}

// Peak price mode - activate standard energy saving.
local const peak: csml.State = new {
  entry {
    Actions.aRaiseEnergySaving
  }
  after {
    ["energyCheck"] = new csml.Timeout {
      delay = "30000"
      do = Actions.aRaiseStartDetectingEnergy
    }
  }
  on {
    [Events.eStartEnergyCheck] = new csml.Transition {
      do {
        new csml.Invoke {
          type = ServiceTypes.stGetEnergyPrice
          raises { new csml.Internal { topic = "priceCheckComplete" } }
        }
      }
    }
    ["priceCheckComplete"] = new csml.Transition {
      do {
        new csml.Eval { expression = "\(Vars.vEnergyPrice) = $energyPrice" }
      }
      to = "fetchingGridStatus"
    }
    [Events.eEnterBusinessHours] = new csml.Transition {
      do { new csml.Eval { expression = "\(Vars.vCurrentSystemScheduleMode) = 'businessHours'" } }
    }
    [Events.eEnterAfterHoursMode] = new csml.Transition {
      do { new csml.Eval { expression = "\(Vars.vCurrentSystemScheduleMode) = 'afterHours'" } }
    }
    [Events.eEnterWeekend] = new csml.Transition {
      do { new csml.Eval { expression = "\(Vars.vCurrentSystemScheduleMode) = 'weekendClosed'" } }
    }
    // Safety
    [Events.eFireAlarm] = new csml.Transition { to = "normal" }
    [Events.eGasLeakDetected] = new csml.Transition { to = "normal" }
    [Events.eSecurityBreachNotification] = new csml.Transition {
      to = "normal"
      iif = Guards.isHighSeverityBreach
    }
  }
}

// Grid demand response mode - activate drastic energy saving.
local const gridRequestResponse: csml.State = new {
  entry {
    Actions.aRaiseDrasticEnergySaving
  }
  after {
    ["energyCheck"] = new csml.Timeout {
      delay = "30000"
      do = Actions.aRaiseStartDetectingEnergy
    }
  }
  on {
    [Events.eStartEnergyCheck] = new csml.Transition {
      do {
        new csml.Invoke {
          type = ServiceTypes.stGetEnergyPrice
          raises { new csml.Internal { topic = "priceCheckComplete" } }
        }
      }
    }
    ["priceCheckComplete"] = new csml.Transition {
      do {
        new csml.Eval { expression = "\(Vars.vEnergyPrice) = $energyPrice" }
      }
      to = "fetchingGridStatus"
    }
    [Events.eEnterBusinessHours] = new csml.Transition {
      do { new csml.Eval { expression = "\(Vars.vCurrentSystemScheduleMode) = 'businessHours'" } }
    }
    [Events.eEnterAfterHoursMode] = new csml.Transition {
      do { new csml.Eval { expression = "\(Vars.vCurrentSystemScheduleMode) = 'afterHours'" } }
    }
    [Events.eEnterWeekend] = new csml.Transition {
      do { new csml.Eval { expression = "\(Vars.vCurrentSystemScheduleMode) = 'weekendClosed'" } }
    }
    [Events.eFireAlarm] = new csml.Transition { to = "normal" }
    [Events.eGasLeakDetected] = new csml.Transition { to = "normal" }
    [Events.eSecurityBreachNotification] = new csml.Transition {
      to = "normal"
      iif = Guards.isHighSeverityBreach
    }
  }
}
